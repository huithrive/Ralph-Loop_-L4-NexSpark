<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Day <%= day.day %>: <%= day.theme %> | Alexandar CGO</title>
  <link rel="stylesheet" href="/css/auxora.css">
  <style>
    .day-container {
      min-height: 100vh;
      background: var(--bg-primary);
    }

    .day-header {
      background: var(--bg-surface);
      border-bottom: 1px solid var(--border-default);
      padding: 16px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .day-header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .back-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      border-radius: 8px;
      background: var(--bg-muted);
      color: var(--text-muted);
      font-size: 0.875rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .back-btn:hover {
      background: var(--primary-coral);
      color: white;
    }

    .day-main {
      max-width: 900px;
      margin: 0 auto;
      padding: 32px;
    }

    .day-hero {
      text-align: center;
      margin-bottom: 40px;
    }

    .day-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 20px;
      background: rgba(196, 112, 74, 0.1);
      color: var(--primary-coral);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 16px;
    }

    .day-hero h1 {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 8px;
    }

    .day-hero p {
      color: var(--text-muted);
      font-size: 1.0625rem;
    }

    .briefing-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 20px;
      padding: 32px;
      margin-bottom: 32px;
    }

    .briefing-header {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 24px;
    }

    .briefing-avatar {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.5rem;
      flex-shrink: 0;
    }

    .briefing-meta {
      flex: 1;
    }

    .briefing-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .briefing-time {
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .briefing-greeting {
      font-size: 1.0625rem;
      color: var(--text-primary);
      line-height: 1.7;
      margin-bottom: 24px;
      padding: 20px;
      background: linear-gradient(135deg, rgba(196, 112, 74, 0.05) 0%, transparent 100%);
      border-radius: 12px;
      border-left: 3px solid var(--primary-coral);
    }

    .overnight-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .overnight-card {
      background: var(--bg-muted);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
    }

    .overnight-value {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .overnight-value.positive {
      color: var(--success);
    }

    .overnight-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .agenda-section {
      margin-top: 24px;
    }

    .agenda-title {
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .agenda-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .agenda-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: var(--bg-muted);
      border-radius: 10px;
    }

    .agenda-time {
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--text-muted);
      width: 80px;
      flex-shrink: 0;
    }

    .agenda-task {
      flex: 1;
      font-size: 0.9375rem;
      color: var(--text-primary);
    }

    .agenda-status {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--success);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
    }

    .activities-section {
      margin-bottom: 32px;
    }

    .activities-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .activities-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border-default);
    }

    .activity-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 16px;
      padding: 24px;
      margin-bottom: 16px;
      transition: all 0.2s ease;
    }

    .activity-card:hover {
      border-color: var(--border-hover);
      box-shadow: var(--shadow-md);
    }

    .activity-card.milestone {
      border-color: var(--primary-coral);
      background: linear-gradient(135deg, rgba(196, 112, 74, 0.03) 0%, var(--bg-surface) 100%);
    }

    .activity-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 16px;
    }

    .activity-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      flex-shrink: 0;
    }

    .activity-icon.research { background: var(--info-light); }
    .activity-icon.insight { background: #F3E8FF; }
    .activity-icon.interview { background: #FEF3C7; }
    .activity-icon.strategy { background: var(--success-light); }
    .activity-icon.approval_request { background: rgba(196, 112, 74, 0.1); }
    .activity-icon.build { background: #DBEAFE; }
    .activity-icon.creative { background: #FCE7F3; }
    .activity-icon.integration { background: #E0E7FF; }
    .activity-icon.campaign { background: #CCFBF1; }
    .activity-icon.launch { background: var(--success-light); }
    .activity-icon.report { background: #F5F5F5; }
    .activity-icon.analysis { background: #FEF9C3; }
    .activity-icon.optimization { background: #D1FAE5; }
    .activity-icon.monitoring { background: #E0E7FF; }
    .activity-icon.alert { background: var(--warning-light); }
    .activity-icon.planning { background: #EDE9FE; }

    .activity-meta {
      flex: 1;
    }

    .activity-title-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 4px;
    }

    .activity-title {
      font-weight: 600;
      font-size: 1.0625rem;
      color: var(--text-primary);
    }

    .activity-time {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--text-muted);
      background: var(--bg-muted);
      padding: 4px 10px;
      border-radius: 6px;
    }

    .activity-badges {
      display: flex;
      gap: 8px;
    }

    .activity-badge {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .activity-badge.approved {
      background: var(--success-light);
      color: var(--success);
    }

    .activity-badge.autonomous {
      background: var(--info-light);
      color: var(--info);
    }

    .activity-badge.milestone {
      background: rgba(196, 112, 74, 0.1);
      color: var(--primary-coral);
    }

    .activity-desc {
      font-size: 0.9375rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .activity-data {
      margin-top: 16px;
      padding: 16px;
      background: var(--bg-muted);
      border-radius: 10px;
    }

    .data-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 16px;
    }

    .data-item {
      text-align: center;
    }

    .data-value {
      font-weight: 600;
      color: var(--text-primary);
    }

    .data-label {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .eod-card {
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      border-radius: 20px;
      padding: 32px;
      color: white;
    }

    .eod-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      opacity: 0.8;
      margin-bottom: 12px;
    }

    .eod-text {
      font-size: 1.0625rem;
      line-height: 1.7;
      margin-bottom: 20px;
    }

    .eod-next {
      padding: 16px 20px;
      background: rgba(255, 255, 255, 0.15);
      border-radius: 12px;
    }

    .eod-next-label {
      font-size: 0.75rem;
      opacity: 0.8;
      margin-bottom: 4px;
    }

    .eod-next-text {
      font-weight: 600;
    }

    .nav-buttons {
      display: flex;
      justify-content: space-between;
      margin-top: 32px;
    }

    .nav-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      border-radius: 10px;
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      color: var(--text-primary);
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .nav-btn:hover {
      border-color: var(--primary-coral);
      color: var(--primary-coral);
    }

    .nav-btn.disabled {
      opacity: 0.5;
      pointer-events: none;
    }

    @media (max-width: 768px) {
      .overnight-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .day-hero h1 {
        font-size: 1.75rem;
      }
    }
  </style>
</head>
<body>
  <div class="day-container">
    <header class="day-header">
      <div class="day-header-left">
        <a href="/alexandar" class="back-btn">
          ← Back to Timeline
        </a>
      </div>
    </header>

    <main class="day-main">
      <div class="day-hero">
        <span class="day-badge">Day <%= day.day %> of 7</span>
        <h1><%= day.dayName %>: <%= day.theme %></h1>
        <p><%= day.date %></p>
      </div>

      <!-- Morning Briefing -->
      <div class="briefing-card">
        <div class="briefing-header">
          <div class="briefing-avatar">A</div>
          <div class="briefing-meta">
            <div class="briefing-title">Morning Briefing</div>
            <div class="briefing-time"><%= demo.user.preferences.briefingTime %> · <%= demo.user.timezone %></div>
          </div>
        </div>

        <div class="briefing-greeting">
          "<%= day.briefing.greeting %>"
        </div>

        <% if (day.briefing.overnight && day.briefing.overnight.spend) { %>
          <div class="overnight-grid">
            <div class="overnight-card">
              <div class="overnight-value"><%= day.briefing.overnight.spend %></div>
              <div class="overnight-label">Overnight Spend</div>
            </div>
            <div class="overnight-card">
              <div class="overnight-value"><%= day.briefing.overnight.conversions %></div>
              <div class="overnight-label">Orders</div>
            </div>
            <div class="overnight-card">
              <div class="overnight-value"><%= day.briefing.overnight.revenue %></div>
              <div class="overnight-label">Revenue</div>
            </div>
            <div class="overnight-card">
              <div class="overnight-value positive"><%= day.briefing.overnight.roas %></div>
              <div class="overnight-label">ROAS</div>
            </div>
          </div>
        <% } %>

        <div class="agenda-section">
          <div class="agenda-title">📋 Today's Agenda</div>
          <div class="agenda-list">
            <% day.briefing.agenda.forEach(function(item) { %>
              <div class="agenda-item">
                <span class="agenda-time"><%= item.time %></span>
                <span class="agenda-task"><%= item.task %></span>
                <span class="agenda-status">✓</span>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Activities -->
      <div class="activities-section">
        <h2 class="activities-title">Activity Log</h2>

        <% day.activities.forEach(function(activity) { %>
          <div class="activity-card <%= activity.milestone ? 'milestone' : '' %>">
            <div class="activity-header">
              <div class="activity-icon <%= activity.type %>">
                <% if (activity.type === 'research') { %>🔍<% } %>
                <% if (activity.type === 'insight') { %>💡<% } %>
                <% if (activity.type === 'interview') { %>🎙️<% } %>
                <% if (activity.type === 'strategy') { %>📋<% } %>
                <% if (activity.type === 'approval_request') { %>✋<% } %>
                <% if (activity.type === 'build') { %>⚡<% } %>
                <% if (activity.type === 'creative') { %>🎨<% } %>
                <% if (activity.type === 'integration') { %>🔗<% } %>
                <% if (activity.type === 'campaign') { %>📢<% } %>
                <% if (activity.type === 'launch') { %>🚀<% } %>
                <% if (activity.type === 'report') { %>📊<% } %>
                <% if (activity.type === 'analysis') { %>📈<% } %>
                <% if (activity.type === 'optimization') { %>⚙️<% } %>
                <% if (activity.type === 'monitoring') { %>👁️<% } %>
                <% if (activity.type === 'alert') { %>⚠️<% } %>
                <% if (activity.type === 'planning') { %>🗓️<% } %>
              </div>
              <div class="activity-meta">
                <div class="activity-title-row">
                  <span class="activity-title"><%= activity.title %></span>
                  <span class="activity-time"><%= activity.time %></span>
                </div>
                <div class="activity-badges">
                  <% if (activity.status === 'approved') { %>
                    <span class="activity-badge approved">Approved</span>
                  <% } %>
                  <% if (activity.autonomous) { %>
                    <span class="activity-badge autonomous">Autonomous</span>
                  <% } %>
                  <% if (activity.milestone) { %>
                    <span class="activity-badge milestone">Milestone</span>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="activity-desc"><%= activity.description %></div>

            <% if (activity.data) { %>
              <div class="activity-data">
                <% if (activity.data.impressions !== undefined) { %>
                  <div class="data-grid">
                    <div class="data-item">
                      <div class="data-value"><%= activity.data.impressions.toLocaleString() %></div>
                      <div class="data-label">Impressions</div>
                    </div>
                    <div class="data-item">
                      <div class="data-value"><%= activity.data.clicks %></div>
                      <div class="data-label">Clicks</div>
                    </div>
                    <div class="data-item">
                      <div class="data-value"><%= activity.data.ctr %></div>
                      <div class="data-label">CTR</div>
                    </div>
                    <div class="data-item">
                      <div class="data-value"><%= activity.data.spend %></div>
                      <div class="data-label">Spend</div>
                    </div>
                  </div>
                <% } %>

                <% if (activity.data.headlines) { %>
                  <div style="font-size: 0.875rem;">
                    <% activity.data.headlines.slice(0, 3).forEach(function(h) { %>
                      <div style="padding: 8px 0; border-bottom: 1px solid var(--border-default); display: flex; justify-content: space-between;">
                        <span>"<%= h.text %>"</span>
                        <span style="color: var(--success); font-weight: 600;"><%= h.score %>%</span>
                      </div>
                    <% }); %>
                  </div>
                <% } %>

                <% if (activity.data.campaigns) { %>
                  <div style="font-size: 0.875rem;">
                    <% activity.data.campaigns.forEach(function(c) { %>
                      <div style="padding: 8px 0; border-bottom: 1px solid var(--border-default); display: flex; justify-content: space-between;">
                        <span><%= c.name %></span>
                        <span style="color: var(--text-muted);"><%= c.budget %></span>
                      </div>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>

      <!-- End of Day -->
      <% if (day.endOfDay) { %>
        <div class="eod-card">
          <div class="eod-label">End of Day Summary</div>
          <div class="eod-text"><%= day.endOfDay.summary %></div>
          <% if (day.endOfDay.nextDay) { %>
            <div class="eod-next">
              <div class="eod-next-label">Tomorrow's Focus</div>
              <div class="eod-next-text"><%= day.endOfDay.nextDay %></div>
            </div>
          <% } %>
        </div>
      <% } %>

      <!-- Navigation -->
      <div class="nav-buttons">
        <a href="<%= day.day > 1 ? '/alexandar/day/' + (day.day - 1) : '#' %>" class="nav-btn <%= day.day === 1 ? 'disabled' : '' %>">
          ← Day <%= day.day - 1 %>
        </a>
        <a href="<%= day.day < 7 ? '/alexandar/day/' + (day.day + 1) : '#' %>" class="nav-btn <%= day.day === 7 ? 'disabled' : '' %>">
          Day <%= day.day + 1 %> →
        </a>
      </div>
    </main>
  </div>
</body>
</html>
