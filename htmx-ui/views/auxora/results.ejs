<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Results - Auxora.ai</title>
  <link rel="stylesheet" href="/css/auxora-theme.css">
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .results-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }

    .hero-result {
      background: var(--auxora-gradient-warm);
      border-radius: var(--auxora-radius-xl);
      padding: 3rem;
      color: white;
      text-align: center;
      margin-bottom: 2rem;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: rgba(255, 255, 255, 0.2);
      border-radius: var(--auxora-radius-full);
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
    }

    .hero-metric {
      font-size: 5rem;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .hero-label {
      font-size: 1.5rem;
      opacity: 0.9;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin: 2rem 0;
    }

    .metric-card {
      background: rgba(255, 255, 255, 0.15);
      border-radius: var(--auxora-radius);
      padding: 1.5rem;
      text-align: center;
    }

    .metric-value {
      font-size: 2rem;
      font-weight: 700;
    }

    .metric-label {
      font-size: 0.875rem;
      opacity: 0.8;
    }

    .section-card {
      background: white;
      border-radius: var(--auxora-radius-lg);
      box-shadow: var(--auxora-shadow);
      margin-bottom: 2rem;
      overflow: hidden;
    }

    .section-header {
      padding: 1.25rem 1.5rem;
      background: var(--auxora-primary-50);
      border-bottom: 1px solid var(--auxora-primary-100);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .section-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--auxora-primary-800);
    }

    .section-content {
      padding: 1.5rem;
    }

    .timeline-visual {
      display: flex;
      justify-content: space-between;
      position: relative;
      padding: 2rem 0;
    }

    .timeline-visual::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 40px;
      right: 40px;
      height: 4px;
      background: linear-gradient(90deg, var(--auxora-error), var(--auxora-warning), var(--auxora-success));
      border-radius: 2px;
      transform: translateY(-50%);
    }

    .timeline-point {
      position: relative;
      z-index: 1;
      text-align: center;
      width: 80px;
    }

    .timeline-dot {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: white;
      border: 4px solid var(--auxora-primary-400);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 0.5rem;
      font-weight: 700;
      color: var(--auxora-primary-700);
    }

    .timeline-point:last-child .timeline-dot {
      border-color: var(--auxora-success);
      background: var(--auxora-success);
      color: white;
    }

    .timeline-roas {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--auxora-primary-800);
    }

    .timeline-label {
      font-size: 0.75rem;
      color: var(--auxora-neutral-500);
    }

    .chart-container {
      height: 300px;
      position: relative;
    }

    .wins-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .win-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      background: var(--auxora-success-light);
      border-radius: var(--auxora-radius);
      border-left: 4px solid var(--auxora-success);
    }

    .win-icon {
      width: 32px;
      height: 32px;
      background: var(--auxora-success);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .stats-row {
      display: flex;
      gap: 3rem;
      justify-content: center;
      padding: 1.5rem;
      background: var(--auxora-primary-50);
      border-radius: var(--auxora-radius);
    }

    .stat-item {
      text-align: center;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--auxora-primary-800);
    }

    .stat-label {
      font-size: 0.75rem;
      color: var(--auxora-neutral-500);
    }

    .cta-section {
      text-align: center;
      padding: 3rem;
      background: var(--auxora-gradient-hero);
      border-radius: var(--auxora-radius-xl);
      margin-top: 2rem;
    }

    @media (max-width: 768px) {
      .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>
</head>
<body class="auxora-app">
  <div class="results-container">
    <!-- Hero Result -->
    <div class="hero-result">
      <div class="hero-badge">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        TARGET ACHIEVED
      </div>
      <div class="hero-metric"><%= demo.results.peakROAS.toFixed(1) %>X</div>
      <div class="hero-label">Peak ROAS Achieved in <%= demo.results.timeline %></div>

      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-value">$<%= demo.results.totalSpend.toFixed(0) %></div>
          <div class="metric-label">Total Spend</div>
        </div>
        <div class="metric-card">
          <div class="metric-value">$<%= demo.results.totalRevenue.toFixed(0) %></div>
          <div class="metric-label">Total Revenue</div>
        </div>
        <div class="metric-card">
          <div class="metric-value"><%= demo.results.totalPurchases %></div>
          <div class="metric-label">Total Purchases</div>
        </div>
        <div class="metric-card">
          <div class="metric-value">$<%= demo.results.customerAcquisitionCost.toFixed(0) %></div>
          <div class="metric-label">Final CPA</div>
        </div>
      </div>
    </div>

    <!-- 5-Week Journey Timeline -->
    <div class="section-card">
      <div class="section-header">
        <span class="section-title">5-Week Transformation Journey</span>
      </div>
      <div class="section-content">
        <div class="timeline-visual">
          <% Object.keys(demo.weeklyData).forEach(function(weekKey) {
            var week = demo.weeklyData[weekKey];
          %>
          <div class="timeline-point">
            <div class="timeline-dot">W<%= week.week %></div>
            <div class="timeline-roas"><%= week.metrics.roas.toFixed(2) %>X</div>
            <div class="timeline-label"><%= week.phase %></div>
          </div>
          <% }); %>
        </div>

        <div class="chart-container" style="margin-top: 2rem;">
          <canvas id="journeyChart"></canvas>
        </div>
      </div>
    </div>

    <!-- OpenClaw Impact -->
    <div class="section-card">
      <div class="section-header">
        <span class="section-title">OpenClaw Impact</span>
        <span class="auxora-badge auxora-badge-success">Autonomous Mode</span>
      </div>
      <div class="section-content">
        <div class="stats-row">
          <div class="stat-item">
            <div class="stat-value"><%= demo.results.autonomousActions %></div>
            <div class="stat-label">Autonomous Actions</div>
          </div>
          <div class="stat-item">
            <div class="stat-value"><%= demo.results.alertsHandled %></div>
            <div class="stat-label">Alerts Handled</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">24/7</div>
            <div class="stat-label">Monitoring</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">30 min</div>
            <div class="stat-label">Heartbeat Interval</div>
          </div>
        </div>

        <div style="margin-top: 2rem;">
          <h4 class="auxora-heading-3" style="margin-bottom: 1rem;">Key Actions Taken</h4>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            <div style="padding: 1rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius);">
              <div style="font-weight: 600; color: var(--auxora-primary-800);">Budget Reallocations</div>
              <div class="auxora-text-sm">Automatically shifted budget from underperforming to winning audiences</div>
            </div>
            <div style="padding: 1rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius);">
              <div style="font-weight: 600; color: var(--auxora-primary-800);">Creative Swaps</div>
              <div class="auxora-text-sm">Replaced fatigued creatives with fresh alternatives</div>
            </div>
            <div style="padding: 1rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius);">
              <div style="font-weight: 600; color: var(--auxora-primary-800);">Bid Adjustments</div>
              <div class="auxora-text-sm">Optimized bids based on performance patterns</div>
            </div>
            <div style="padding: 1rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius);">
              <div style="font-weight: 600; color: var(--auxora-primary-800);">Threshold Alerts</div>
              <div class="auxora-text-sm">Proactively notified on performance changes</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Key Wins -->
    <div class="section-card">
      <div class="section-header">
        <span class="section-title">Key Wins</span>
      </div>
      <div class="section-content">
        <div class="wins-list">
          <% demo.results.keyWins.forEach(function(win) { %>
          <div class="win-item">
            <div class="win-icon">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <div style="font-weight: 600; color: var(--auxora-primary-800);"><%= win %></div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Top Performers -->
    <div class="section-card">
      <div class="section-header">
        <span class="section-title">Top Performers</span>
      </div>
      <div class="section-content">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
          <div>
            <div class="auxora-label">Top Audience</div>
            <div style="padding: 1.5rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius); text-align: center;">
              <div style="font-size: 2rem; font-weight: 700; color: var(--auxora-primary-700);"><%= demo.results.topAudience %></div>
              <div class="auxora-text-sm">Best performing audience segment</div>
            </div>
          </div>
          <div>
            <div class="auxora-label">Top Creative</div>
            <div style="padding: 1.5rem; background: var(--auxora-primary-50); border-radius: var(--auxora-radius); text-align: center;">
              <div style="font-size: 2rem; font-weight: 700; color: var(--auxora-primary-700);"><%= demo.results.topCreative %></div>
              <div class="auxora-text-sm">Highest engagement creative</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="cta-section">
      <h2 class="auxora-heading-2" style="margin-bottom: 1rem;">Ready to Scale Your Brand?</h2>
      <p class="auxora-text" style="margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
        Auxora.ai is your AI growth co-founder. From strategy to execution to optimization - we handle it all.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/auxora" class="auxora-btn auxora-btn-primary auxora-btn-lg">
          Start Your Growth Journey
        </a>
        <a href="/auxora/openclaw" class="auxora-btn auxora-btn-secondary auxora-btn-lg">
          See OpenClaw in Action
        </a>
      </div>
    </div>
  </div>

  <script>
    // Journey Chart
    var journeyCtx = document.getElementById('journeyChart').getContext('2d');
    new Chart(journeyCtx, {
      type: 'line',
      data: {
        labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5'],
        datasets: [{
          label: 'Revenue',
          data: [38.50, 78.00, 312.00, 396.00, 945.00],
          borderColor: '#F59E0B',
          backgroundColor: 'rgba(245, 158, 11, 0.1)',
          fill: true,
          tension: 0.4,
          yAxisID: 'y'
        }, {
          label: 'ROAS',
          data: [0.80, 1.50, 1.99, 1.99, 3.02],
          borderColor: '#22C55E',
          borderDash: [5, 5],
          fill: false,
          tension: 0.4,
          yAxisID: 'y1'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false
        },
        plugins: {
          legend: {
            position: 'bottom'
          }
        },
        scales: {
          y: {
            type: 'linear',
            display: true,
            position: 'left',
            title: {
              display: true,
              text: 'Revenue ($)'
            }
          },
          y1: {
            type: 'linear',
            display: true,
            position: 'right',
            title: {
              display: true,
              text: 'ROAS'
            },
            grid: {
              drawOnChartArea: false
            }
          }
        }
      }
    });
  </script>
</body>
</html>
