<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>OpenClaw Monitoring - Auxora.ai</title>
  <link rel="stylesheet" href="/css/auxora-theme.css">
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    .openclaw-container {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 2rem;
      max-width: 1600px;
      margin: 0 auto;
      padding: 2rem;
      min-height: 100vh;
    }

    .monitoring-panel {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .conversation-panel {
      background: white;
      border-radius: var(--auxora-radius-lg);
      box-shadow: var(--auxora-shadow);
      display: flex;
      flex-direction: column;
      height: calc(100vh - 4rem);
      position: sticky;
      top: 2rem;
    }

    .conversation-header {
      padding: 1.5rem;
      border-bottom: 1px solid var(--auxora-primary-100);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .conversation-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1rem;
    }

    .conversation-input {
      padding: 1rem;
      border-top: 1px solid var(--auxora-primary-100);
    }

    .heartbeat-hero {
      background: var(--auxora-gradient-warm);
      border-radius: var(--auxora-radius-xl);
      padding: 2rem;
      color: white;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .heartbeat-visual {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .heartbeat-icon {
      width: 80px;
      height: 80px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: heartbeat-glow 2s infinite;
    }

    @keyframes heartbeat-glow {
      0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.4); }
      50% { box-shadow: 0 0 0 20px transparent; }
    }

    .heartbeat-stats {
      display: flex;
      gap: 2rem;
    }

    .heartbeat-stat {
      text-align: center;
    }

    .heartbeat-stat-value {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .heartbeat-stat-label {
      font-size: 0.75rem;
      opacity: 0.8;
    }

    .section-card {
      background: white;
      border-radius: var(--auxora-radius-lg);
      box-shadow: var(--auxora-shadow);
      overflow: hidden;
    }

    .section-header {
      padding: 1.25rem 1.5rem;
      background: var(--auxora-primary-50);
      border-bottom: 1px solid var(--auxora-primary-100);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .section-title {
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--auxora-primary-800);
    }

    .section-content {
      padding: 1.5rem;
    }

    .alert-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      border-radius: var(--auxora-radius);
      margin-bottom: 0.75rem;
    }

    .alert-item.critical {
      background: var(--auxora-error-light);
      border-left: 4px solid var(--auxora-error);
    }

    .alert-item.warning {
      background: var(--auxora-warning-light);
      border-left: 4px solid var(--auxora-warning);
    }

    .alert-item.info {
      background: var(--auxora-info-light);
      border-left: 4px solid var(--auxora-info);
    }

    .action-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      border-bottom: 1px solid var(--auxora-primary-100);
    }

    .action-item:last-child {
      border-bottom: none;
    }

    .action-icon {
      width: 40px;
      height: 40px;
      border-radius: var(--auxora-radius);
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--auxora-success-light);
      color: var(--auxora-success);
    }

    .action-icon.pending {
      background: var(--auxora-warning-light);
      color: var(--auxora-warning);
    }

    .permission-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .permission-card {
      padding: 1rem;
      background: var(--auxora-primary-50);
      border-radius: var(--auxora-radius);
    }

    .permission-label {
      font-size: 0.75rem;
      color: var(--auxora-neutral-500);
      margin-bottom: 0.25rem;
    }

    .permission-value {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--auxora-primary-800);
    }

    .weekly-report-card {
      background: linear-gradient(135deg, var(--auxora-primary-100), var(--auxora-secondary-100));
      border-radius: var(--auxora-radius-lg);
      padding: 2rem;
      margin-top: 1.5rem;
    }

    .metrics-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .metric-card {
      background: white;
      border-radius: var(--auxora-radius);
      padding: 1rem;
      text-align: center;
    }

    .chart-container {
      height: 200px;
      position: relative;
    }

    .performer-table {
      width: 100%;
      border-collapse: collapse;
    }

    .performer-table th {
      text-align: left;
      padding: 0.75rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--auxora-neutral-500);
      border-bottom: 1px solid var(--auxora-primary-100);
    }

    .performer-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--auxora-primary-100);
    }

    @media (max-width: 1200px) {
      .openclaw-container {
        grid-template-columns: 1fr;
      }

      .conversation-panel {
        position: relative;
        height: auto;
        max-height: 500px;
      }
    }
  </style>
</head>
<body class="auxora-app">
  <div class="openclaw-container">
    <!-- Monitoring Panel -->
    <div class="monitoring-panel">
      <!-- Header -->
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
          <a href="/auxora" style="color: var(--auxora-primary-600); text-decoration: none; font-size: 0.875rem;">
            &larr; Back to Dashboard
          </a>
          <h1 class="auxora-heading-1" style="margin-top: 0.5rem;">OpenClaw Monitoring</h1>
          <p class="auxora-text">Autonomous optimization for <%= demo.client.company %></p>
        </div>
      </div>

      <!-- Heartbeat Hero -->
      <div class="heartbeat-hero">
        <div class="heartbeat-visual">
          <div class="heartbeat-icon">
            <svg width="40" height="40" fill="white" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <div style="font-size: 1.5rem; font-weight: 700;">Heartbeat Active</div>
            <div style="opacity: 0.8;">Monitoring every 30 minutes</div>
          </div>
        </div>
        <div class="heartbeat-stats">
          <div class="heartbeat-stat">
            <div class="heartbeat-stat-value">2 min</div>
            <div class="heartbeat-stat-label">Last Check</div>
          </div>
          <div class="heartbeat-stat">
            <div class="heartbeat-stat-value">28 min</div>
            <div class="heartbeat-stat-label">Next Check</div>
          </div>
          <div class="heartbeat-stat">
            <div class="heartbeat-stat-value"><%= demo.openClaw.alerts.length %></div>
            <div class="heartbeat-stat-label">Active Alerts</div>
          </div>
          <div class="heartbeat-stat">
            <div class="heartbeat-stat-value"><%= demo.openClaw.actionsTaken.length %></div>
            <div class="heartbeat-stat-label">Actions Today</div>
          </div>
        </div>
      </div>

      <!-- Active Alerts -->
      <div class="section-card">
        <div class="section-header">
          <span class="section-title">Active Alerts</span>
          <span class="auxora-badge auxora-badge-warning"><%= demo.openClaw.alerts.length %> pending</span>
        </div>
        <div class="section-content">
          <% if (demo.openClaw.alerts.length === 0) { %>
          <div style="text-align: center; padding: 2rem; color: var(--auxora-neutral-500);">
            <svg width="48" height="48" fill="currentColor" style="opacity: 0.3;" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <div style="margin-top: 0.5rem;">All clear! No active alerts.</div>
          </div>
          <% } else { %>
          <% demo.openClaw.alerts.forEach(function(alert) { %>
          <div class="alert-item <%= alert.severity %>" id="alert-<%= alert.id %>">
            <div style="flex: 1;">
              <div style="font-weight: 600; color: var(--auxora-primary-900);"><%= alert.message %></div>
              <div class="auxora-text-sm" style="margin-top: 0.25rem;">
                <%= alert.metric %>: <%= alert.currentValue %> (threshold: <%= alert.threshold %>)
              </div>
              <div style="margin-top: 1rem;">
                <span class="auxora-text-sm" style="font-weight: 500;">Recommended:</span>
                <span class="auxora-text-sm"><%= alert.recommendedAction.rationale %></span>
              </div>
              <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                <button class="auxora-btn auxora-btn-primary auxora-btn-sm" onclick="approveAlert('<%= alert.id %>')">
                  Approve Action
                </button>
                <button class="auxora-btn auxora-btn-secondary auxora-btn-sm" onclick="dismissAlert('<%= alert.id %>')">
                  Dismiss
                </button>
                <button class="auxora-btn auxora-btn-ghost auxora-btn-sm">
                  View Details
                </button>
              </div>
            </div>
          </div>
          <% }); %>
          <% } %>
        </div>
      </div>

      <!-- Autonomous Actions -->
      <div class="section-card">
        <div class="section-header">
          <span class="section-title">Autonomous Actions Taken</span>
          <span class="auxora-badge auxora-badge-success"><%= demo.openClaw.actionsTaken.length %> today</span>
        </div>
        <div class="section-content">
          <% demo.openClaw.actionsTaken.forEach(function(action) { %>
          <div class="action-item">
            <div class="action-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            </div>
            <div style="flex: 1;">
              <div style="font-weight: 600; color: var(--auxora-primary-800);"><%= action.description %></div>
              <div class="auxora-text-sm" style="margin-top: 0.25rem;"><%= action.rationale %></div>
            </div>
            <div class="auxora-text-xs" style="color: var(--auxora-neutral-400);">
              <%= new Date(action.executedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Permissions/Boundaries -->
      <div class="section-card">
        <div class="section-header">
          <span class="section-title">Autonomous Boundaries</span>
          <button class="auxora-btn auxora-btn-ghost auxora-btn-sm">Edit</button>
        </div>
        <div class="section-content">
          <div class="permission-grid">
            <div class="permission-card">
              <div class="permission-label">Budget Reallocation Limit</div>
              <div class="permission-value"><%= (demo.openClaw.permissions.budgetReallocationLimit * 100) %>%</div>
            </div>
            <div class="permission-card">
              <div class="permission-label">Auto-Pause ROAS Threshold</div>
              <div class="permission-value"><%= demo.openClaw.permissions.autoPauseRoasThreshold %>X</div>
            </div>
            <div class="permission-card">
              <div class="permission-label">Auto-Scale ROAS Threshold</div>
              <div class="permission-value"><%= demo.openClaw.permissions.autoScaleRoasThreshold %>X</div>
            </div>
            <div class="permission-card">
              <div class="permission-label">Require Approval Above</div>
              <div class="permission-value">$<%= demo.openClaw.permissions.requireApprovalAbove %></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Weekly Report Preview -->
      <div class="section-card">
        <div class="section-header">
          <span class="section-title">Weekly Sync Report</span>
          <span class="auxora-badge auxora-badge-primary">Week <%= demo.openClaw.weeklyReport.week %></span>
        </div>
        <div class="section-content">
          <div class="weekly-report-card">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-size: 0.875rem; color: var(--auxora-primary-600);">Week <%= demo.openClaw.weeklyReport.week %> Summary</div>
                <div style="font-size: 1.25rem; font-weight: 700; color: var(--auxora-primary-900);"><%= demo.openClaw.weeklyReport.dateRange %></div>
              </div>
              <div style="text-align: right;">
                <div style="font-size: 2rem; font-weight: 700; color: var(--auxora-primary-700);"><%= demo.openClaw.weeklyReport.summary.roas.toFixed(2) %>X</div>
                <div class="auxora-text-sm" style="color: var(--auxora-success);">
                  +<%= demo.openClaw.weeklyReport.comparison.roasChangePercent %>% vs last week
                </div>
              </div>
            </div>

            <div class="metrics-row">
              <div class="metric-card">
                <div class="auxora-text-xs">Total Spend</div>
                <div style="font-size: 1.25rem; font-weight: 700;">$<%= demo.openClaw.weeklyReport.summary.totalSpend.toFixed(2) %></div>
              </div>
              <div class="metric-card">
                <div class="auxora-text-xs">Revenue</div>
                <div style="font-size: 1.25rem; font-weight: 700;">$<%= demo.openClaw.weeklyReport.summary.totalRevenue.toFixed(2) %></div>
              </div>
              <div class="metric-card">
                <div class="auxora-text-xs">Purchases</div>
                <div style="font-size: 1.25rem; font-weight: 700;"><%= demo.openClaw.weeklyReport.summary.purchases %></div>
              </div>
              <div class="metric-card">
                <div class="auxora-text-xs">CPA</div>
                <div style="font-size: 1.25rem; font-weight: 700;">$<%= demo.openClaw.weeklyReport.summary.cpa.toFixed(2) %></div>
              </div>
            </div>
          </div>

          <!-- Top Performers -->
          <h4 class="auxora-heading-3" style="margin: 2rem 0 1rem;">Top Performers</h4>
          <table class="performer-table">
            <thead>
              <tr>
                <th>Audience</th>
                <th>ROAS</th>
                <th>Spend</th>
                <th>Revenue</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% demo.openClaw.weeklyReport.topPerformers.audiences.forEach(function(aud) { %>
              <tr>
                <td><%= aud.name %></td>
                <td><strong><%= aud.roas %>X</strong></td>
                <td>$<%= aud.spend.toFixed(2) %></td>
                <td>$<%= aud.revenue.toFixed(2) %></td>
                <td>
                  <span class="auxora-badge <%= aud.status === 'scale' ? 'auxora-badge-success' : 'auxora-badge-primary' %>">
                    <%= aud.status %>
                  </span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>

          <!-- Bottom Performers -->
          <h4 class="auxora-heading-3" style="margin: 2rem 0 1rem;">Needs Attention</h4>
          <table class="performer-table">
            <thead>
              <tr>
                <th>Audience</th>
                <th>ROAS</th>
                <th>Spend</th>
                <th>Revenue</th>
                <th>Recommendation</th>
              </tr>
            </thead>
            <tbody>
              <% demo.openClaw.weeklyReport.bottomPerformers.audiences.forEach(function(aud) { %>
              <tr>
                <td><%= aud.name %></td>
                <td style="color: var(--auxora-error);"><strong><%= aud.roas %>X</strong></td>
                <td>$<%= aud.spend.toFixed(2) %></td>
                <td>$<%= aud.revenue.toFixed(2) %></td>
                <td>
                  <span class="auxora-badge auxora-badge-error"><%= aud.recommendation %></span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>

          <!-- Next Week Plan -->
          <h4 class="auxora-heading-3" style="margin: 2rem 0 1rem;">Next Week Action Plan</h4>
          <div class="auxora-timeline">
            <% demo.openClaw.weeklyReport.nextWeekPlan.forEach(function(item) { %>
            <div class="auxora-timeline-item">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span class="auxora-badge auxora-badge-primary">P<%= item.priority %></span>
                <span><%= item.action %></span>
              </div>
            </div>
            <% }); %>
          </div>

          <button class="auxora-btn auxora-btn-primary auxora-w-full" style="margin-top: 2rem;">
            Download Full Report (PDF)
          </button>
        </div>
      </div>
    </div>

    <!-- Conversation Panel -->
    <div class="conversation-panel">
      <div class="conversation-header">
        <div class="auxora-chat-avatar auxora">A</div>
        <div>
          <div style="font-weight: 600; color: var(--auxora-primary-800);">Auxora</div>
          <div class="auxora-text-xs">Daily Check-in</div>
        </div>
        <div class="auxora-heartbeat" style="margin-left: auto; padding: 0.25rem 0.5rem;">
          <span class="auxora-heartbeat-pulse"></span>
        </div>
      </div>

      <div class="conversation-messages" id="chat-messages">
        <% demo.openClaw.dailyCheckin.messages.forEach(function(msg) { %>
        <div class="auxora-chat-message <%= msg.role %>" style="margin-bottom: 1rem;">
          <%- msg.content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>') %>
          <% if (msg.actions) { %>
          <div style="margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
            <% msg.actions.forEach(function(action) { %>
            <button class="auxora-btn auxora-btn-sm <%= action.action === 'pause_and_reallocate' ? 'auxora-btn-primary' : 'auxora-btn-secondary' %>" onclick="handleAction('<%= action.action %>')">
              <%= action.label %>
            </button>
            <% }); %>
          </div>
          <% } %>
        </div>
        <% }); %>
      </div>

      <div class="conversation-input">
        <div style="display: flex; gap: 0.5rem;">
          <input type="text" class="auxora-input" placeholder="Ask Auxora anything..." id="chat-input">
          <button class="auxora-btn auxora-btn-primary" style="padding: 0.75rem;">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function approveAlert(alertId) {
      var alertEl = document.getElementById('alert-' + alertId);
      alertEl.className = 'alert-item info';
      alertEl.innerHTML = '<div style="display: flex; align-items: center; gap: 1rem;"><div style="background: var(--auxora-success); padding: 0.5rem; border-radius: var(--auxora-radius);"><svg width="20" height="20" fill="white" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></div><div><div style="font-weight: 600; color: var(--auxora-success);">Action Approved</div><div class="auxora-text-sm">Ad set paused and budget reallocated.</div></div></div>';
      addChatMessage('auxora', "Done! I've paused the underperforming ad set and reallocated the budget to your winning audiences. I'll monitor performance and update you on the results.");
    }

    function dismissAlert(alertId) {
      var alertEl = document.getElementById('alert-' + alertId);
      alertEl.style.display = 'none';
      addChatMessage('auxora', "Got it! I'll keep monitoring and let you know if things change.");
    }

    function handleAction(action) {
      if (action === 'pause_and_reallocate') {
        addChatMessage('auxora', "Done! I've paused the underperforming ad set and moved the budget to Wagyu Enthusiasts. Expect to see improved ROAS within the next 24-48 hours.");
      } else if (action === 'continue') {
        addChatMessage('auxora', "Understood! I'll keep monitoring and alert you if performance drops further.");
      } else {
        addChatMessage('auxora', "No problem! Take your time to review the data. I'm here whenever you need me.");
      }
    }

    function addChatMessage(role, content) {
      var messagesContainer = document.getElementById('chat-messages');
      var messageDiv = document.createElement('div');
      messageDiv.className = 'auxora-chat-message ' + role;
      messageDiv.style.marginBottom = '1rem';
      messageDiv.innerHTML = content.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
      messagesContainer.appendChild(messageDiv);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // Handle chat input
    document.getElementById('chat-input').addEventListener('keypress', function(e) {
      if (e.key === 'Enter' && this.value.trim()) {
        var message = this.value;
        addChatMessage('user', message);
        this.value = '';

        // Simulate response
        setTimeout(function() {
          var responses = [
            "Based on the current data, I recommend focusing budget on the Wagyu Enthusiasts audience - they're showing the best ROAS at 3.1X.",
            "The weekly spend is on track. At this pace, you'll hit your $800 monthly budget target while maintaining positive ROAS.",
            "I'm seeing good engagement on video creatives. The 'Sizzle Video' is outperforming static images by 2.5X on CTR."
          ];
          addChatMessage('auxora', responses[Math.floor(Math.random() * responses.length)]);
        }, 1000);
      }
    });
  </script>
</body>
</html>
