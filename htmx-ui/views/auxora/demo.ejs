<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auxora.ai - AI Growth Co-Founder Demo</title>
  <link rel="stylesheet" href="/css/auxora-theme.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

    .demo-app {
      display: flex;
      height: 100vh;
      background: #FFFBEB;
    }

    /* ===== LEFT PANEL - CHAT ===== */
    .chat-panel {
      width: 420px;
      background: white;
      border-right: 2px solid #FDE68A;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    .chat-header {
      padding: 20px;
      background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
      color: white;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .chat-avatar {
      width: 48px;
      height: 48px;
      background: rgba(255,255,255,0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.25rem;
    }

    .chat-info h2 {
      margin: 0;
      font-size: 1.125rem;
      font-weight: 600;
    }

    .chat-info p {
      margin: 4px 0 0;
      font-size: 0.8125rem;
      opacity: 0.9;
    }

    .heartbeat-indicator {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.2);
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 0.75rem;
    }

    .heartbeat-dot {
      width: 8px;
      height: 8px;
      background: #22C55E;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
      50% { transform: scale(1.2); box-shadow: 0 0 0 8px transparent; }
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .message {
      display: flex;
      gap: 12px;
      max-width: 90%;
      animation: messageIn 0.3s ease-out;
    }

    @keyframes messageIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .message.auxora { align-self: flex-start; }
    .message.user { align-self: flex-end; flex-direction: row-reverse; }

    .message-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.875rem;
      flex-shrink: 0;
    }

    .message.auxora .message-avatar {
      background: linear-gradient(135deg, #F59E0B, #D97706);
      color: white;
    }

    .message.user .message-avatar {
      background: #E7E5E4;
      color: #57534E;
    }

    .message-content {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .message.user .message-content { align-items: flex-end; }

    .message-bubble {
      padding: 12px 16px;
      border-radius: 16px;
      font-size: 0.9375rem;
      line-height: 1.5;
    }

    .message.auxora .message-bubble {
      background: #FEF3C7;
      color: #78350F;
      border-bottom-left-radius: 4px;
    }

    .message.user .message-bubble {
      background: #F59E0B;
      color: white;
      border-bottom-right-radius: 4px;
    }

    .message-time {
      font-size: 0.6875rem;
      color: #A8A29E;
      padding: 0 4px;
    }

    /* Action Buttons in Chat */
    .action-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .action-btn {
      padding: 10px 20px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.875rem;
      border: 2px solid #F59E0B;
      cursor: pointer;
      transition: all 0.2s ease;
      background: white;
      color: #D97706;
    }

    .action-btn:hover {
      background: #F59E0B;
      color: white;
    }

    .action-btn.primary {
      background: #F59E0B;
      color: white;
    }

    .action-btn.primary:hover {
      background: #D97706;
    }

    /* Typing Indicator */
    .typing-indicator {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .typing-dots {
      display: flex;
      gap: 4px;
      padding: 12px 16px;
      background: #FEF3C7;
      border-radius: 16px;
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #D97706;
      animation: typingBounce 1.4s ease-in-out infinite;
    }

    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    @keyframes typingBounce {
      0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; }
      40% { transform: scale(1); opacity: 1; }
    }

    /* Chat Input */
    .chat-input-area {
      padding: 16px 20px;
      border-top: 1px solid #FDE68A;
      display: flex;
      gap: 12px;
    }

    .chat-input {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid #FDE68A;
      border-radius: 24px;
      font-size: 0.9375rem;
      outline: none;
    }

    .chat-input:focus {
      border-color: #F59E0B;
    }

    .send-btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #F59E0B;
      border: none;
      color: white;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ===== RIGHT PANEL - CONTENT ===== */
    .content-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* Tabs */
    .content-tabs {
      display: flex;
      background: white;
      border-bottom: 2px solid #FDE68A;
      padding: 0 24px;
    }

    .content-tab {
      padding: 16px 24px;
      font-size: 0.9375rem;
      font-weight: 500;
      color: #78716C;
      border: none;
      background: none;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      margin-bottom: -2px;
      transition: all 0.2s ease;
    }

    .content-tab:hover {
      color: #D97706;
    }

    .content-tab.active {
      color: #D97706;
      border-bottom-color: #F59E0B;
      font-weight: 600;
    }

    .content-tab.locked {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .content-tab .tab-icon {
      margin-right: 8px;
    }

    /* Content Area */
    .content-area {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
    }

    .content-section {
      display: none;
    }

    .content-section.active {
      display: block;
    }

    /* Cards */
    .card {
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(120, 53, 15, 0.1);
      margin-bottom: 20px;
      overflow: hidden;
    }

    .card-header {
      padding: 16px 20px;
      background: #FFFBEB;
      border-bottom: 1px solid #FDE68A;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-title {
      font-weight: 600;
      color: #78350F;
      font-size: 1rem;
    }

    .card-body {
      padding: 20px;
    }

    /* Metrics Grid */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .metric-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      border: 2px solid #FDE68A;
    }

    .metric-value {
      font-size: 2rem;
      font-weight: 700;
      color: #D97706;
    }

    .metric-label {
      font-size: 0.75rem;
      color: #78716C;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-top: 4px;
    }

    .metric-change {
      font-size: 0.8125rem;
      margin-top: 4px;
    }

    .metric-change.positive { color: #22C55E; }
    .metric-change.negative { color: #EF4444; }

    /* Progress Steps */
    .progress-steps {
      display: flex;
      justify-content: space-between;
      margin-bottom: 32px;
      position: relative;
    }

    .progress-steps::before {
      content: '';
      position: absolute;
      top: 20px;
      left: 40px;
      right: 40px;
      height: 3px;
      background: #FDE68A;
    }

    .progress-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .step-number {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: white;
      border: 3px solid #FDE68A;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #A8A29E;
    }

    .progress-step.completed .step-number {
      background: #22C55E;
      border-color: #22C55E;
      color: white;
    }

    .progress-step.active .step-number {
      background: #F59E0B;
      border-color: #F59E0B;
      color: white;
      animation: stepPulse 2s infinite;
    }

    @keyframes stepPulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
      50% { box-shadow: 0 0 0 10px transparent; }
    }

    .step-label {
      margin-top: 8px;
      font-size: 0.75rem;
      font-weight: 500;
      color: #78716C;
    }

    .progress-step.active .step-label,
    .progress-step.completed .step-label {
      color: #D97706;
    }

    /* Input Form */
    .url-input-group {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
    }

    .url-input {
      flex: 1;
      padding: 16px 20px;
      border: 2px solid #FDE68A;
      border-radius: 12px;
      font-size: 1rem;
    }

    .url-input:focus {
      outline: none;
      border-color: #F59E0B;
    }

    .submit-btn {
      padding: 16px 32px;
      background: linear-gradient(135deg, #F59E0B, #D97706);
      color: white;
      border: none;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
    }

    /* Research Results */
    .research-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .research-item {
      padding: 16px;
      background: #FFFBEB;
      border-radius: 12px;
      border-left: 4px solid #F59E0B;
    }

    .research-item-label {
      font-size: 0.75rem;
      color: #78716C;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .research-item-value {
      font-weight: 600;
      color: #78350F;
    }

    /* Voice Call Overlay */
    .voice-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.8);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .voice-overlay.active {
      display: flex;
    }

    .voice-modal {
      background: white;
      border-radius: 24px;
      padding: 40px;
      text-align: center;
      width: 90%;
      max-width: 480px;
    }

    .voice-avatar {
      width: 120px;
      height: 120px;
      background: linear-gradient(135deg, #F59E0B, #D97706);
      border-radius: 50%;
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: voicePulse 1.5s infinite;
    }

    @keyframes voicePulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
      50% { transform: scale(1.05); box-shadow: 0 0 0 20px transparent; }
    }

    .voice-waveform {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      height: 60px;
      margin: 24px 0;
    }

    .voice-bar {
      width: 6px;
      background: #F59E0B;
      border-radius: 3px;
      animation: voiceBar 0.5s ease-in-out infinite alternate;
    }

    .voice-bar:nth-child(1) { animation-delay: 0s; height: 20px; }
    .voice-bar:nth-child(2) { animation-delay: 0.1s; height: 35px; }
    .voice-bar:nth-child(3) { animation-delay: 0.2s; height: 50px; }
    .voice-bar:nth-child(4) { animation-delay: 0.3s; height: 35px; }
    .voice-bar:nth-child(5) { animation-delay: 0.4s; height: 45px; }
    .voice-bar:nth-child(6) { animation-delay: 0.3s; height: 30px; }
    .voice-bar:nth-child(7) { animation-delay: 0.2s; height: 40px; }
    .voice-bar:nth-child(8) { animation-delay: 0.1s; height: 25px; }

    @keyframes voiceBar {
      0% { transform: scaleY(0.5); }
      100% { transform: scaleY(1); }
    }

    /* Payment Modal */
    .payment-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.8);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .payment-overlay.active {
      display: flex;
    }

    .payment-modal {
      background: white;
      border-radius: 24px;
      padding: 40px;
      text-align: center;
      width: 90%;
      max-width: 400px;
    }

    .payment-amount {
      font-size: 4rem;
      font-weight: 700;
      color: #D97706;
    }

    .payment-features {
      text-align: left;
      margin: 24px 0;
    }

    .payment-feature {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 0;
      color: #57534E;
    }

    .payment-feature::before {
      content: '✓';
      color: #22C55E;
      font-weight: 600;
    }

    /* Chart Container */
    .chart-container {
      height: 250px;
      position: relative;
    }

    /* Timeline */
    .timeline {
      position: relative;
      padding-left: 32px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: #FDE68A;
    }

    .timeline-item {
      position: relative;
      padding-bottom: 24px;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: -32px;
      top: 4px;
      width: 16px;
      height: 16px;
      background: white;
      border: 3px solid #F59E0B;
      border-radius: 50%;
    }

    .timeline-item.completed::before {
      background: #22C55E;
      border-color: #22C55E;
    }

    /* Alert Banner */
    .alert-banner {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: 16px 20px;
      border-radius: 12px;
      margin-bottom: 20px;
    }

    .alert-banner.warning {
      background: #FEF9C3;
      border-left: 4px solid #EAB308;
    }

    .alert-banner.success {
      background: #DCFCE7;
      border-left: 4px solid #22C55E;
    }

    /* Tables */
    .data-table {
      width: 100%;
      border-collapse: collapse;
    }

    .data-table th {
      text-align: left;
      padding: 12px 16px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #78716C;
      background: #FFFBEB;
      border-bottom: 2px solid #FDE68A;
    }

    .data-table td {
      padding: 12px 16px;
      border-bottom: 1px solid #FDE68A;
    }

    /* Badge */
    .badge {
      display: inline-flex;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge.success { background: #DCFCE7; color: #166534; }
    .badge.warning { background: #FEF9C3; color: #854D0E; }
    .badge.primary { background: #FEF3C7; color: #92400E; }
  </style>
</head>
<body>
  <div class="demo-app">
    <!-- ===== LEFT: CHAT PANEL ===== -->
    <div class="chat-panel">
      <div class="chat-header">
        <div class="chat-avatar">A</div>
        <div class="chat-info">
          <h2>Auxora</h2>
          <p>Your AI Growth Co-Founder</p>
        </div>
        <div class="heartbeat-indicator">
          <span class="heartbeat-dot"></span>
          <span>Active</span>
        </div>
      </div>

      <div class="chat-messages" id="chat-messages">
        <!-- Messages will be injected here -->
      </div>

      <div class="chat-input-area">
        <input type="text" class="chat-input" placeholder="Type a message..." id="chat-input">
        <button class="send-btn" onclick="handleUserInput()">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
        </button>
      </div>
    </div>

    <!-- ===== RIGHT: CONTENT PANEL ===== -->
    <div class="content-panel">
      <!-- Tabs -->
      <div class="content-tabs">
        <button class="content-tab active" data-tab="onboarding">
          <span class="tab-icon">1</span> Onboarding
        </button>
        <button class="content-tab locked" data-tab="execution">
          <span class="tab-icon">2</span> Execution
        </button>
        <button class="content-tab locked" data-tab="openclaw">
          <span class="tab-icon">3</span> OpenClaw
        </button>
        <button class="content-tab locked" data-tab="results">
          <span class="tab-icon">4</span> Results
        </button>
      </div>

      <!-- Content Area -->
      <div class="content-area">
        <!-- ONBOARDING SECTION -->
        <div class="content-section active" id="section-onboarding">
          <!-- Progress Steps -->
          <div class="progress-steps">
            <div class="progress-step active" id="step-1">
              <div class="step-number">1</div>
              <span class="step-label">Enter URL</span>
            </div>
            <div class="progress-step" id="step-2">
              <div class="step-number">2</div>
              <span class="step-label">Research</span>
            </div>
            <div class="progress-step" id="step-3">
              <div class="step-number">3</div>
              <span class="step-label">Interview</span>
            </div>
            <div class="progress-step" id="step-4">
              <div class="step-number">4</div>
              <span class="step-label">GTM Report</span>
            </div>
          </div>

          <!-- Dynamic Content -->
          <div id="onboarding-content">
            <div class="card">
              <div class="card-header">
                <span class="card-title">Enter Your Website</span>
              </div>
              <div class="card-body">
                <p style="color: #57534E; margin-bottom: 16px;">Let's start by analyzing your business. Enter your website URL below.</p>
                <div class="url-input-group">
                  <input type="url" class="url-input" id="website-url" placeholder="https://yourwebsite.com" value="https://yamabushifarms.com">
                  <button class="submit-btn" onclick="startResearch()">Analyze</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- EXECUTION SECTION -->
        <div class="content-section" id="section-execution">
          <div id="execution-content">
            <!-- Will be populated dynamically -->
          </div>
        </div>

        <!-- OPENCLAW SECTION -->
        <div class="content-section" id="section-openclaw">
          <div id="openclaw-content">
            <!-- Will be populated dynamically -->
          </div>
        </div>

        <!-- RESULTS SECTION -->
        <div class="content-section" id="section-results">
          <div id="results-content">
            <!-- Will be populated dynamically -->
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Voice Interview Overlay -->
  <div class="voice-overlay" id="voice-overlay">
    <div class="voice-modal">
      <div class="voice-avatar">
        <svg width="48" height="48" fill="white" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7 4a3 3 0 016 0v4a3 3 0 11-6 0V4zm4 10.93A7.001 7.001 0 0017 8a1 1 0 10-2 0A5 5 0 015 8a1 1 0 00-2 0 7.001 7.001 0 006 6.93V17H6a1 1 0 100 2h8a1 1 0 100-2h-3v-2.07z" clip-rule="evenodd"/></svg>
      </div>
      <h2 style="color: #78350F; margin-bottom: 8px;">Voice Interview</h2>
      <p style="color: #57534E;" id="voice-question">Tell me about your brand. What makes YamaBushi Farms special?</p>
      <div class="voice-waveform">
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
        <div class="voice-bar"></div>
      </div>
      <p style="color: #A8A29E; font-size: 0.875rem;">Question <span id="voice-q-num">1</span> of 8</p>
      <div style="margin-top: 24px; display: flex; gap: 12px; justify-content: center;">
        <button class="action-btn" onclick="nextVoiceQuestion()">Next Question</button>
        <button class="action-btn" style="border-color: #E7E5E4; color: #57534E;" onclick="endVoiceCall()">End Call</button>
      </div>
    </div>
  </div>

  <!-- Payment Overlay -->
  <div class="payment-overlay" id="payment-overlay">
    <div class="payment-modal">
      <p style="color: #A8A29E; margin-bottom: 8px;" id="payment-label">GTM Strategy Preview</p>
      <div class="payment-amount">$<span id="payment-amount">1.99</span></div>
      <div class="payment-features" id="payment-features">
        <div class="payment-feature">Complete market analysis</div>
        <div class="payment-feature">Voice interview session</div>
