        if (i < step) el.classList.add('completed');
        if (i === step) el.classList.add('active');
      }
      currentStep = step;
    }

    function unlockTab(tabName) {
      const tab = document.querySelector(`[data-tab="${tabName}"]`);
      if (tab) tab.classList.remove('locked');
