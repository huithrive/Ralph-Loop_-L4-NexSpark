      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function hideTyping() {
      const typing = document.getElementById('typing');
      if (typing) typing.remove();
    }

    async function playConversation(flowKey) {
      const messages = conversationFlow[flowKey];
      if (!messages) return;

      for (const msg of messages) {
        showTyping();
        await delay(msg.delay || 1200);
        hideTyping();

        if (msg.sender === 'auxora') {
          addMessage('auxora', msg.text, msg.buttons);
        }

        if (msg.showPayment) {
          await delay(500);
          showPayment(msg.showPayment);
          return; // Wait for payment
        }

        if (msg.action) {
          await delay(500);
          handleAction(msg.action);
        }

        await delay(300);
      }
    }

    function delay(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

