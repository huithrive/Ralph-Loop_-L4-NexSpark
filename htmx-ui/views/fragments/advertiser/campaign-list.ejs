<div class="table-wrap animate-fade-in">
  <table>
    <thead>
      <tr>
        <th>Campaign</th>
        <th>Platform</th>
        <th>Status</th>
        <th>Budget</th>
        <th>Spent</th>
        <th>Impressions</th>
        <th>CTR</th>
        <th>Conversions</th>
        <th>ROAS</th>
      </tr>
    </thead>
    <tbody>
      <% campaigns.forEach(function(c) { %>
        <tr>
          <td class="font-bold text-white"><%= c.name %></td>
          <td><span class="badge badge-info"><%= c.platform %></span></td>
          <td>
            <span class="badge badge-<%= c.status === 'active' ? 'success' : c.status === 'paused' ? 'warning' : 'neutral' %>"><%= c.status %></span>
          </td>
          <td><%= c.budget %></td>
          <td><%= c.spent %></td>
          <td><%= c.impressions %></td>
          <td><%= c.ctr %></td>
          <td class="text-gold font-bold"><%= c.conversions %></td>
          <td class="text-success font-bold"><%= c.roas %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
