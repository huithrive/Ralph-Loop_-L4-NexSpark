<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sakura SourceFlow - Interactive Demo</title>
  <link rel="stylesheet" href="/css/auxora.css">
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      background: #0B141A;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .demo-app {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* Sidebar */
    .demo-sidebar {
      width: 340px;
      background: var(--bg-surface);
      border-right: 1px solid var(--border-default);
      display: flex;
      flex-direction: column;
    }

    .sidebar-header {
      padding: 20px;
      border-bottom: 1px solid var(--border-default);
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .sidebar-logo-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.25rem;
    }

    .sidebar-logo-text {
      font-family: var(--font-display);
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .sidebar-logo-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .user-card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: var(--bg-muted);
      border-radius: 12px;
    }

    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #FFB7C5 0%, #FCD5CE 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      color: #9D4C3C;
    }

    .user-info {
      flex: 1;
    }

    .user-name {
      font-weight: 600;
      color: var(--text-primary);
      font-size: 0.9375rem;
    }

    .user-company {
      font-size: 0.8125rem;
      color: var(--text-muted);
    }

    .day-nav {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }

    .day-nav-title {
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 12px;
      padding: 0 8px;
    }

    .day-btn {
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
      padding: 12px 16px;
      background: transparent;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      margin-bottom: 4px;
    }

    .day-btn:hover {
      background: var(--bg-muted);
    }

    .day-btn.active {
      background: rgba(196, 112, 74, 0.1);
    }

    .day-btn-num {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: var(--bg-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.875rem;
      color: var(--text-muted);
    }

    .day-btn.active .day-btn-num {
      background: var(--primary-coral);
      color: white;
    }

    .day-btn.completed .day-btn-num {
      background: var(--success);
      color: white;
    }

    .day-btn-info {
      flex: 1;
    }

    .day-btn-title {
      font-weight: 500;
      color: var(--text-primary);
      font-size: 0.875rem;
    }

    .day-btn.active .day-btn-title {
      color: var(--primary-coral);
    }

    .day-btn-sub {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .channel-badge {
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .channel-badge.slack {
      background: #4A154B;
      color: white;
    }

    .channel-badge.whatsapp {
      background: #25D366;
      color: white;
    }

    /* Chat Area */
    .chat-area {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: #0B141A;
    }

    .chat-area.slack {
      background: #1A1D21;
    }

    .chat-area.whatsapp {
      background: #0B141A;
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .chat-header {
      padding: 16px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .chat-header-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.125rem;
    }

    .chat-header-info {
      flex: 1;
    }

    .chat-header-name {
      font-weight: 600;
      color: white;
      font-size: 1rem;
    }

    .chat-header-status {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.6);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #25D366;
    }

    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .date-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px 0;
    }

    .date-divider span {
      background: rgba(255,255,255,0.1);
      color: rgba(255,255,255,0.6);
      padding: 6px 16px;
      border-radius: 8px;
      font-size: 0.75rem;
    }

    .message {
      display: flex;
      gap: 12px;
      max-width: 85%;
      animation: messageIn 0.3s ease-out;
    }

    @keyframes messageIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .message.alexandar {
      align-self: flex-start;
    }

    .message.david {
      align-self: flex-end;
      flex-direction: row-reverse;
    }

    .message-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.875rem;
      flex-shrink: 0;
    }

    .message.alexandar .message-avatar {
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      color: white;
    }

    .message.david .message-avatar {
      background: linear-gradient(135deg, #FFB7C5 0%, #FCD5CE 100%);
      color: #9D4C3C;
    }

    .message-content {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .message.david .message-content {
      align-items: flex-end;
    }

    .message-bubble {
      padding: 12px 16px;
      border-radius: 16px;
      font-size: 0.9375rem;
      line-height: 1.5;
      max-width: 100%;
    }

    .message.alexandar .message-bubble {
      background: #202C33;
      color: white;
      border-bottom-left-radius: 4px;
    }

    .message.david .message-bubble {
      background: #005C4B;
      color: white;
      border-bottom-right-radius: 4px;
    }

    .slack .message.alexandar .message-bubble {
      background: #222529;
    }

    .slack .message.david .message-bubble {
      background: #1264A3;
    }

    .message-time {
      font-size: 0.6875rem;
      color: rgba(255,255,255,0.4);
      padding: 0 4px;
    }

    /* Card Messages */
    .message-card {
      background: #202C33;
      border-radius: 12px;
      overflow: hidden;
      min-width: 320px;
      max-width: 420px;
    }

    .slack .message-card {
      background: #222529;
    }

    .card-header {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card-icon {
      font-size: 1.25rem;
    }

    .card-title {
      font-weight: 600;
      color: white;
      font-size: 0.9375rem;
    }

    .card-body {
      padding: 16px;
    }

    .card-text {
      color: rgba(255,255,255,0.8);
      font-size: 0.875rem;
      margin-bottom: 12px;
    }

    .card-data {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .card-data.cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }

    .card-data-item {
      text-align: center;
      padding: 10px;
      background: rgba(255,255,255,0.05);
      border-radius: 8px;
    }

    .card-data-value {
      font-weight: 600;
      color: white;
      font-size: 1rem;
    }

    .card-data-value.positive {
      color: #25D366;
    }

    .card-data-value.warning {
      color: #F59E0B;
    }

    .card-data-label {
      font-size: 0.6875rem;
      color: rgba(255,255,255,0.5);
      text-transform: uppercase;
    }

    /* Checklist Card */
    .checklist-items {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .checklist-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 8px;
      font-size: 0.875rem;
      color: rgba(255,255,255,0.8);
    }

    .checklist-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
    }

    .checklist-icon.done {
      background: #25D366;
      color: white;
    }

    .checklist-icon.in_progress {
      background: #3B82F6;
      color: white;
    }

    .checklist-icon.pending {
      background: rgba(255,255,255,0.2);
      color: white;
    }

    /* Creative Card */
    .creative-preview {
      background: rgba(255,255,255,0.05);
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 12px;
    }

    .creative-headline {
      font-size: 1rem;
      font-weight: 600;
      color: white;
      margin-bottom: 8px;
      line-height: 1.4;
    }

    .creative-detail {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 4px;
    }

    .creative-cta {
      display: inline-block;
      margin-top: 12px;
      padding: 8px 16px;
      background: var(--primary-coral);
      color: white;
      border-radius: 6px;
      font-size: 0.8125rem;
      font-weight: 600;
    }

    /* Campaign Card */
    .campaign-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 12px;
    }

    .campaign-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 12px;
      background: rgba(255,255,255,0.05);
      border-radius: 8px;
    }

    .campaign-name {
      font-weight: 500;
      color: white;
      font-size: 0.875rem;
    }

    .campaign-budget {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.6);
    }

    .adset-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .adset-item {
      display: flex;
      justify-content: space-between;
      padding: 8px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 6px;
      font-size: 0.8125rem;
    }

    .adset-name {
      color: rgba(255,255,255,0.8);
    }

    .adset-targeting {
      color: rgba(255,255,255,0.5);
    }

    /* Approval Card */
    .approval-card {
      background: linear-gradient(135deg, rgba(196, 112, 74, 0.2) 0%, rgba(196, 112, 74, 0.1) 100%);
      border: 1px solid rgba(196, 112, 74, 0.3);
    }

    .approval-actions {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .approval-btn {
      flex: 1;
      padding: 10px 16px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .approval-btn.primary {
      background: var(--primary-coral);
      color: white;
    }

    .approval-btn.primary:hover {
      background: var(--primary-coral-hover);
    }

    .approval-btn.secondary {
      background: rgba(255,255,255,0.1);
      color: white;
    }

    /* Alert Card */
    .alert-card {
      border-left: 4px solid;
    }

    .alert-card.success {
      border-color: #25D366;
      background: rgba(37, 211, 102, 0.1);
    }

    .alert-card.warning {
      border-color: #F59E0B;
      background: rgba(245, 158, 11, 0.1);
    }

    .alert-card.opportunity {
      border-color: var(--primary-coral);
      background: rgba(196, 112, 74, 0.1);
    }

    .alert-data {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      margin-top: 12px;
    }

    .alert-data-item {
      padding: 8px;
      background: rgba(255,255,255,0.05);
      border-radius: 6px;
    }

    .alert-data-label {
      font-size: 0.6875rem;
      color: rgba(255,255,255,0.5);
      text-transform: uppercase;
    }

    .alert-data-value {
      font-size: 0.875rem;
      color: white;
      font-weight: 500;
    }

    /* Milestone Card */
    .milestone-card {
      background: linear-gradient(135deg, var(--primary-coral) 0%, var(--primary-coral-glow) 100%);
      text-align: center;
      padding: 24px;
    }

    .milestone-card .card-header {
      border: none;
      justify-content: center;
    }

    .milestone-card .card-title {
      font-size: 1.25rem;
    }

    /* Briefing Card */
    .briefing-card .card-body {
      padding: 0;
    }

    .briefing-greeting {
      padding: 16px;
      color: rgba(255,255,255,0.9);
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    .briefing-overnight {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(255,255,255,0.1);
    }

    .briefing-overnight-item {
      background: #202C33;
      padding: 12px;
      text-align: center;
    }

    .slack .briefing-overnight-item {
      background: #222529;
    }

    /* Metrics Table */
    .metrics-table {
      width: 100%;
      border-collapse: collapse;
    }

    .metrics-table tr {
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .metrics-table tr:last-child {
      border-bottom: none;
    }

    .metrics-table td {
      padding: 8px 4px;
      font-size: 0.8125rem;
    }

    .metrics-table td:first-child {
      color: rgba(255,255,255,0.6);
    }

    .metrics-table td:nth-child(2) {
      color: white;
      font-weight: 500;
      text-align: center;
    }

    .metrics-table td:last-child {
      text-align: right;
    }

    .status-check {
      color: #25D366;
    }

    .status-rocket {
      color: var(--primary-coral);
    }

    /* Insights Card */
    .insights-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .insight-item {
      padding: 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 8px;
      border-left: 3px solid var(--primary-coral);
    }

    .insight-finding {
      font-weight: 600;
      color: white;
      font-size: 0.875rem;
      margin-bottom: 4px;
    }

    .insight-detail {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.6);
      margin-bottom: 8px;
    }

    .insight-action {
      font-size: 0.8125rem;
      color: var(--primary-coral);
      font-weight: 500;
    }

    /* Proposal Card */
    .proposal-allocation {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin: 12px 0;
    }

    .allocation-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 6px;
      font-size: 0.8125rem;
    }

    .allocation-audience {
      color: rgba(255,255,255,0.9);
    }

    .allocation-budget {
      color: white;
      font-weight: 500;
    }

    .allocation-change {
      font-size: 0.75rem;
      color: #25D366;
    }

    .allocation-change.negative {
      color: #F59E0B;
    }

    .allocation-change.paused {
      color: #EF4444;
    }

    /* Action Items Card */
    .action-items-section {
      margin-bottom: 16px;
    }

    .action-items-section:last-child {
      margin-bottom: 0;
    }

    .action-items-title {
      font-size: 0.75rem;
      color: var(--primary-coral);
      text-transform: uppercase;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .action-items-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .action-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.8);
    }

    .action-item::before {
      content: '•';
      color: var(--primary-coral);
    }

    /* Recommendation Card */
    .recommendation-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .recommendation-item {
      padding: 10px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 8px;
    }

    .recommendation-label {
      font-size: 0.6875rem;
      color: rgba(255,255,255,0.5);
      text-transform: uppercase;
      margin-bottom: 4px;
    }

    .recommendation-text {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.9);
    }

    /* Typing Indicator */
    .typing-indicator {
      display: flex;
      gap: 12px;
      align-items: center;
      padding: 12px 0;
    }

    .typing-dots {
      display: flex;
      gap: 4px;
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.4);
      animation: typingBounce 1.4s ease-in-out infinite;
    }

    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    @keyframes typingBounce {
      0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; }
      40% { transform: scale(1); opacity: 1; }
    }

    /* Controls */
    .demo-controls {
      padding: 16px 24px;
      background: rgba(0,0,0,0.3);
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .control-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.9375rem;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .control-btn.primary {
      background: var(--primary-coral);
      color: white;
    }

    .control-btn.primary:hover {
      background: var(--primary-coral-hover);
    }

    .control-btn.secondary {
      background: rgba(255,255,255,0.1);
      color: white;
    }

    .control-btn.secondary:hover {
      background: rgba(255,255,255,0.2);
    }

    .control-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .progress-info {
      color: rgba(255,255,255,0.6);
      font-size: 0.875rem;
    }

    .speed-control {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .speed-control label {
      color: rgba(255,255,255,0.6);
      font-size: 0.8125rem;
    }

    .speed-select {
      background: rgba(255,255,255,0.1);
      border: none;
      color: white;
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 0.8125rem;
    }
  </style>
</head>
<body>
  <div class="demo-app">
    <!-- Sidebar -->
    <aside class="demo-sidebar">
      <div class="sidebar-header">
        <div class="sidebar-logo">
          <div class="sidebar-logo-icon">A</div>
          <div>
            <div class="sidebar-logo-text">Alexandar</div>
            <div class="sidebar-logo-sub">Chief Growth Officer</div>
          </div>
        </div>
        <div class="user-card">
          <div class="user-avatar">DC</div>
          <div class="user-info">
            <div class="user-name"><%= client.name %></div>
            <div class="user-company"><%= client.company %></div>
          </div>
        </div>
      </div>

      <div class="day-nav">
        <div class="day-nav-title">Execution Timeline</div>
        <% Object.keys(conversations).forEach(function(key, index) { %>
          <% var conv = conversations[key]; %>
          <button class="day-btn <%= index === 0 ? 'active' : '' %>" data-day="<%= key %>">
            <div class="day-btn-num"><%= index + 1 %></div>
            <div class="day-btn-info">
              <div class="day-btn-title"><%= conv.theme %></div>
              <div class="day-btn-sub"><%= conv.date %></div>
            </div>
            <span class="channel-badge <%= conv.channel %>"><%= conv.channel %></span>
          </button>
        <% }); %>
      </div>
    </aside>

    <!-- Chat Area -->
    <main class="chat-area slack" id="chat-area">
      <div class="chat-header">
        <div class="chat-header-avatar">A</div>
        <div class="chat-header-info">
          <div class="chat-header-name">Alexandar</div>
          <div class="chat-header-status">
            <span class="status-dot"></span>
            <span id="status-text">Online</span>
          </div>
        </div>
      </div>

      <div class="chat-messages" id="chat-messages">
        <div class="date-divider"><span id="date-display">Monday, Jan 13</span></div>
        <!-- Messages will be injected here -->
      </div>

      <div class="demo-controls">
        <div class="speed-control">
          <label>Speed:</label>
          <select class="speed-select" id="speed-select">
            <option value="0.5">0.5x</option>
            <option value="1" selected>1x</option>
            <option value="2">2x</option>
            <option value="5">5x (Fast)</option>
          </select>
        </div>
        <div class="progress-info" id="progress-info">Message 0 of 0</div>
        <div style="display: flex; gap: 12px;">
          <button class="control-btn secondary" id="restart-btn">Restart</button>
          <button class="control-btn primary" id="play-btn">Play Demo</button>
        </div>
      </div>
    </main>
  </div>

  <script>
    const conversations = <%- JSON.stringify(conversations) %>;
    const dayKeys = Object.keys(conversations);

    let currentDay = dayKeys[0];
    let currentMessageIndex = 0;
    let isPlaying = false;
    let timeoutId = null;
    let speed = 1;

    const chatMessages = document.getElementById('chat-messages');
    const playBtn = document.getElementById('play-btn');
    const restartBtn = document.getElementById('restart-btn');
    const speedSelect = document.getElementById('speed-select');
    const progressInfo = document.getElementById('progress-info');
    const dateDisplay = document.getElementById('date-display');
    const chatArea = document.getElementById('chat-area');
    const statusText = document.getElementById('status-text');

    // Day navigation
    document.querySelectorAll('.day-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentDay = btn.dataset.day;
        loadDay(currentDay);
      });
    });

    function loadDay(day) {
      const conv = conversations[day];
      currentMessageIndex = 0;
      isPlaying = false;
      clearTimeout(timeoutId);

      // Update UI
      chatArea.className = 'chat-area ' + conv.channel;
      dateDisplay.textContent = conv.date;
      chatMessages.innerHTML = '<div class="date-divider"><span>' + conv.date + '</span></div>';
      playBtn.textContent = 'Play Demo';
      updateProgress();
    }

    function updateProgress() {
      const conv = conversations[currentDay];
      progressInfo.textContent = 'Message ' + currentMessageIndex + ' of ' + conv.messages.length;
    }

    function renderMessage(msg) {
      const div = document.createElement('div');
      const sender = msg.sender === 'alexandar' ? 'alexandar' : 'david';

      if (msg.type === 'text') {
        div.className = 'message ' + sender;
        div.innerHTML = `
          <div class="message-avatar">${sender === 'alexandar' ? 'A' : 'DC'}</div>
          <div class="message-content">
            <div class="message-bubble">${formatText(msg.content)}</div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'action') {
        div.className = 'message david';
        div.innerHTML = `
          <div class="message-avatar">DC</div>
          <div class="message-content">
            <div class="message-bubble">${msg.content}</div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'card') {
        div.className = 'message alexandar';
        let cardHtml = renderCard(msg);
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            ${cardHtml}
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'approval') {
        div.className = 'message alexandar';
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            <div class="message-card approval-card">
              <div class="card-header">
                <span class="card-icon">${msg.title.split(' ')[0]}</span>
                <span class="card-title">${msg.title.split(' ').slice(1).join(' ')}</span>
              </div>
              <div class="card-body">
                <div class="card-text">${msg.content}</div>
                ${msg.data ? renderApprovalData(msg.data) : ''}
                <div class="approval-actions">
                  ${msg.actions.map((a, i) => `
                    <button class="approval-btn ${i === 0 ? 'primary' : 'secondary'}">${a}</button>
                  `).join('')}
                </div>
              </div>
            </div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'alert') {
        div.className = 'message alexandar';
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            <div class="message-card alert-card ${msg.alertType}">
              <div class="card-header">
                <span class="card-icon">${msg.title.split(' ')[0]}</span>
                <span class="card-title">${msg.title.split(' ').slice(1).join(' ')}</span>
              </div>
              <div class="card-body">
                <div class="card-text">${msg.content}</div>
                ${msg.data ? renderAlertData(msg.data) : ''}
              </div>
            </div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'milestone') {
        div.className = 'message alexandar';
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            <div class="message-card milestone-card">
              <div class="card-header">
                <span class="card-title">${msg.title}</span>
              </div>
              <div class="card-body">
                <div class="card-text" style="text-align:center;color:white;margin:0;">${msg.content}</div>
              </div>
            </div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'briefing') {
        div.className = 'message alexandar';
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            <div class="message-card briefing-card">
              <div class="card-header">
                <span class="card-icon">${msg.title.split(' ')[0]}</span>
                <span class="card-title">${msg.title.split(' ').slice(1).join(' ')}</span>
              </div>
              <div class="card-body">
                <div class="briefing-greeting">${msg.content}</div>
                ${msg.overnight ? renderOvernightData(msg.overnight) : ''}
                ${msg.data ? renderBriefingData(msg.data) : ''}
              </div>
            </div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      } else if (msg.type === 'notification') {
        div.className = 'message alexandar';
        const icon = msg.notificationType === 'auto' ? '⚙️' : msg.notificationType === 'insight' ? '💡' : msg.notificationType === 'update' ? '✅' : '📢';
        div.innerHTML = `
          <div class="message-avatar">A</div>
          <div class="message-content">
            <div class="message-card">
              <div class="card-header">
                <span class="card-icon">${icon}</span>
                <span class="card-title">${msg.title}</span>
              </div>
              <div class="card-body">
                <div class="card-text" style="margin:0;">${msg.content}</div>
              </div>
            </div>
            <div class="message-time">${msg.time}</div>
          </div>
        `;
      }

      return div;
    }

    function formatText(text) {
      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>');
    }

    function renderCard(msg) {
      const cardType = msg.cardType;
      let bodyContent = '';

      if (cardType === 'checklist' && msg.data && msg.data.items) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div class="checklist-items">
            ${msg.data.items.map(item => `
              <div class="checklist-item">
                <span class="checklist-icon ${item.status}">${item.status === 'done' ? '✓' : item.status === 'in_progress' ? '◉' : '○'}</span>
                <span>${item.task}</span>
              </div>
            `).join('')}
          </div>
        `;
      } else if (cardType === 'creative' && msg.data) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div class="creative-preview">
            <div class="creative-headline">${msg.data.headline}</div>
            <div class="creative-detail"><strong>Visual:</strong> ${msg.data.visual}</div>
            ${msg.data.format ? `<div class="creative-detail"><strong>Format:</strong> ${msg.data.format}</div>` : ''}
            ${msg.data.hypothesis ? `<div class="creative-detail" style="color:var(--primary-coral);"><strong>Test:</strong> ${msg.data.hypothesis}</div>` : ''}
            <span class="creative-cta">${msg.data.cta}</span>
          </div>
        `;
      } else if (cardType === 'campaign' && msg.data) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div class="campaign-list">
            ${msg.data.campaigns.map(c => `
              <div class="campaign-item">
                <span class="campaign-name">${c.name}</span>
                <span class="campaign-budget">${c.budget}</span>
              </div>
            `).join('')}
          </div>
          <div class="adset-list">
            ${msg.data.adSets.map(a => `
              <div class="adset-item">
                <span class="adset-name">${a.name}</span>
                <span class="adset-targeting">${a.budget}</span>
              </div>
            `).join('')}
          </div>
        `;
      } else if (cardType === 'report' && msg.data) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div class="card-data cols-3">
            ${Object.entries(msg.data).filter(([k]) => k !== 'note' && k !== 'adSets').map(([key, val]) => `
              <div class="card-data-item">
                <div class="card-data-value ${key.toLowerCase().includes('roas') || key.toLowerCase().includes('revenue') ? 'positive' : ''}">${val}</div>
                <div class="card-data-label">${key.replace(/([A-Z])/g, ' $1').trim()}</div>
              </div>
            `).join('')}
          </div>
          ${msg.data.note ? `<div style="margin-top:12px;font-size:0.8125rem;color:#25D366;">${msg.data.note}</div>` : ''}
        `;
      } else if (cardType === 'analysis' && msg.data && msg.data.adSets) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div class="adset-list">
            ${msg.data.adSets.map(a => `
              <div class="adset-item" style="padding:10px 12px;">
                <span class="adset-name">${a.name}</span>
                <span style="color:rgba(255,255,255,0.7);">CTR: ${a.ctr}</span>
                <span style="color:rgba(255,255,255,0.5);">${a.spend}</span>
                <span>${a.status}</span>
              </div>
            `).join('')}
          </div>
        `;
      } else if (cardType === 'sync' && msg.data) {
        bodyContent = `
          <div style="text-align:center;padding:8px 0;">
            <div style="font-size:0.875rem;color:rgba(255,255,255,0.6);">${msg.subtitle || ''}</div>
            <div style="margin-top:12px;display:flex;justify-content:center;gap:24px;">
              <div>
                <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);">Status</div>
                <div style="font-size:1rem;color:#25D366;font-weight:600;">${msg.data.status}</div>
              </div>
              <div>
                <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);">Confidence</div>
                <div style="font-size:1rem;color:white;font-weight:600;">${msg.data.confidence}</div>
              </div>
            </div>
          </div>
        `;
      } else if (cardType === 'metrics' && msg.data && msg.data.metrics) {
        bodyContent = `
          <table class="metrics-table">
            ${msg.data.metrics.map(m => `
              <tr>
                <td>${m.name}</td>
                <td>${m.actual}</td>
                <td><span class="${m.status.includes('🚀') ? 'status-rocket' : 'status-check'}">${m.status}</span></td>
              </tr>
            `).join('')}
          </table>
        `;
      } else if (cardType === 'insights' && msg.data && msg.data.learnings) {
        bodyContent = `
          <div class="insights-list">
            ${msg.data.learnings.map(l => `
              <div class="insight-item">
                <div class="insight-finding">${l.finding}</div>
                <div class="insight-detail">${l.detail}</div>
                <div class="insight-action">→ ${l.action}</div>
              </div>
            `).join('')}
          </div>
        `;
      } else if (cardType === 'proposal' && msg.data) {
        bodyContent = `
          <div class="card-text">${msg.content}</div>
          <div style="background:rgba(255,255,255,0.05);padding:12px;border-radius:8px;margin-bottom:12px;">
            <div style="font-size:0.75rem;color:rgba(255,255,255,0.5);">Budget Change</div>
            <div style="font-size:1.125rem;color:#25D366;font-weight:600;">${msg.data.budgetChange}</div>
            <div style="font-size:0.8125rem;color:rgba(255,255,255,0.6);margin-top:4px;">${msg.data.rationale}</div>
          </div>
          ${msg.data.allocation ? `
            <div class="proposal-allocation">
              ${msg.data.allocation.map(a => `
                <div class="allocation-item">
                  <span class="allocation-audience">${a.audience}</span>
                  <span class="allocation-budget">${a.budget}</span>
                  <span class="allocation-change ${a.change.includes('-') ? 'negative' : a.change === 'Paused' ? 'paused' : ''}">${a.change}</span>
                </div>
              `).join('')}
            </div>
          ` : ''}
          ${msg.data.projectedROAS ? `
            <div style="display:flex;justify-content:space-between;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,0.1);">
              <div>
                <div style="font-size:0.6875rem;color:rgba(255,255,255,0.5);">Projected ROAS</div>
                <div style="color:white;font-weight:500;">${msg.data.projectedROAS}</div>
              </div>
              <div>
                <div style="font-size:0.6875rem;color:rgba(255,255,255,0.5);">Projected Revenue</div>
                <div style="color:#25D366;font-weight:500;">${msg.data.projectedRevenue}</div>
              </div>
            </div>
          ` : ''}
        `;
      } else if (cardType === 'action-items' && msg.data) {
        bodyContent = `
          ${msg.data.alexandar ? `
            <div class="action-items-section">
              <div class="action-items-title">Alexandar</div>
              <div class="action-items-list">
                ${msg.data.alexandar.map(item => `<div class="action-item">${item}</div>`).join('')}
              </div>
            </div>
          ` : ''}
          ${msg.data.david ? `
            <div class="action-items-section">
              <div class="action-items-title">David</div>
              <div class="action-items-list">
                ${msg.data.david.map(item => `<div class="action-item">${item}</div>`).join('')}
              </div>
            </div>
          ` : ''}
        `;
      } else if (cardType === 'recommendation' && msg.data) {
        bodyContent = `
          <div class="recommendation-list">
            ${msg.data.immediate ? `
              <div class="recommendation-item">
                <div class="recommendation-label">Immediate</div>
                <div class="recommendation-text">${msg.data.immediate}</div>
              </div>
            ` : ''}
            ${msg.data.shortTerm ? `
              <div class="recommendation-item">
                <div class="recommendation-label">Short Term</div>
                <div class="recommendation-text">${msg.data.shortTerm}</div>
              </div>
            ` : ''}
            ${msg.data.test ? `
              <div class="recommendation-item">
                <div class="recommendation-label">Test</div>
                <div class="recommendation-text">${msg.data.test}</div>
              </div>
            ` : ''}
          </div>
        `;
      } else {
        // Generic card
        bodyContent = `<div class="card-text">${msg.content}</div>`;
        if (msg.data) {
          const dataItems = Object.entries(msg.data).filter(([k, v]) => typeof v !== 'object');
          if (dataItems.length > 0) {
            bodyContent += `
              <div class="card-data">
                ${dataItems.map(([key, val]) => `
                  <div class="card-data-item">
                    <div class="card-data-value">${val}</div>
                    <div class="card-data-label">${key.replace(/([A-Z])/g, ' $1').trim()}</div>
                  </div>
                `).join('')}
              </div>
            `;
          }
        }
      }

      return `
        <div class="message-card">
          <div class="card-header">
            <span class="card-icon">${msg.title.split(' ')[0]}</span>
            <span class="card-title">${msg.title.split(' ').slice(1).join(' ')}</span>
          </div>
          <div class="card-body">${bodyContent}</div>
        </div>
      `;
    }

    function renderApprovalData(data) {
      return `
        <div class="card-data" style="margin-bottom:8px;">
          ${Object.entries(data).filter(([k, v]) => typeof v !== 'object').map(([key, val]) => `
            <div class="card-data-item">
              <div class="card-data-value">${val}</div>
              <div class="card-data-label">${key.replace(/([A-Z])/g, ' $1').trim()}</div>
            </div>
          `).join('')}
        </div>
      `;
    }

    function renderAlertData(data) {
      return `
        <div class="alert-data">
          ${Object.entries(data).map(([key, val]) => `
            <div class="alert-data-item">
              <div class="alert-data-label">${key.replace(/([A-Z])/g, ' $1').trim()}</div>
              <div class="alert-data-value">${val}</div>
            </div>
          `).join('')}
        </div>
      `;
    }

    function renderOvernightData(overnight) {
      return `
        <div class="briefing-overnight">
          <div class="briefing-overnight-item">
            <div class="card-data-value">${overnight.spend}</div>
            <div class="card-data-label">Spend</div>
          </div>
          <div class="briefing-overnight-item">
            <div class="card-data-value">${overnight.orders}</div>
            <div class="card-data-label">Orders</div>
          </div>
          <div class="briefing-overnight-item">
            <div class="card-data-value positive">${overnight.roas}</div>
            <div class="card-data-label">ROAS</div>
          </div>
        </div>
      `;
    }

    function renderBriefingData(data) {
      const items = Object.entries(data).filter(([k, v]) => typeof v !== 'object');
      if (items.length === 0) return '';

      return `
        <div class="card-data cols-3" style="padding:16px;">
          ${items.map(([key, val]) => `
            <div class="card-data-item">
              <div class="card-data-value ${key.toLowerCase().includes('roas') || key.toLowerCase().includes('revenue') ? 'positive' : ''}">${val}</div>
              <div class="card-data-label">${key.replace(/([A-Z])/g, ' $1').trim()}</div>
            </div>
          `).join('')}
        </div>
      `;
    }

    function showTyping() {
      const div = document.createElement('div');
      div.className = 'typing-indicator';
      div.id = 'typing';
      div.innerHTML = `
        <div class="message-avatar" style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#C4704A,#E8956F);display:flex;align-items:center;justify-content:center;color:white;font-weight:600;">A</div>
        <div class="typing-dots">
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
          <span class="typing-dot"></span>
        </div>
      `;
      chatMessages.appendChild(div);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function hideTyping() {
      const typing = document.getElementById('typing');
      if (typing) typing.remove();
    }

    async function playNext() {
      const conv = conversations[currentDay];
      if (currentMessageIndex >= conv.messages.length) {
        isPlaying = false;
        playBtn.textContent = 'Complete';

        // Mark day as completed
        document.querySelectorAll('.day-btn').forEach(btn => {
          if (btn.dataset.day === currentDay) {
            btn.classList.add('completed');
          }
        });
        return;
      }

      const msg = conv.messages[currentMessageIndex];

      // Show typing for Alexandar messages
      if (msg.sender === 'alexandar') {
        statusText.textContent = 'typing...';
        showTyping();
        await new Promise(r => setTimeout(r, (800 + Math.random() * 400) / speed));
        hideTyping();
        statusText.textContent = 'Online';
      }

      const element = renderMessage(msg);
      chatMessages.appendChild(element);
      chatMessages.scrollTop = chatMessages.scrollHeight;

      currentMessageIndex++;
      updateProgress();

      // Calculate delay to next message
      let delay = 1500;
      if (msg.waitForUser) {
        delay = 2500; // Longer pause for "user" messages
      }
      if (msg.type === 'card' || msg.type === 'briefing' || msg.type === 'approval') {
        delay = 2000; // Longer pause for cards
      }

      if (isPlaying && currentMessageIndex < conv.messages.length) {
        timeoutId = setTimeout(playNext, delay / speed);
      } else if (currentMessageIndex >= conv.messages.length) {
        playBtn.textContent = 'Complete';
      }
    }

    playBtn.addEventListener('click', () => {
      if (isPlaying) {
        isPlaying = false;
        clearTimeout(timeoutId);
        playBtn.textContent = 'Resume';
      } else {
        isPlaying = true;
        playBtn.textContent = 'Pause';
        playNext();
      }
    });

    restartBtn.addEventListener('click', () => {
      loadDay(currentDay);
    });

    speedSelect.addEventListener('change', (e) => {
      speed = parseFloat(e.target.value);
    });

    // Initialize
    loadDay(dayKeys[0]);
  </script>
</body>
</html>
