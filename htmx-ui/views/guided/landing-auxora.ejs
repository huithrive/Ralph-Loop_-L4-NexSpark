<div class="landing-content">
  <div class="landing-brand">
    <div class="landing-tagline">AI Growth Studio</div>
    <div class="landing-logo">NexSpark</div>
  </div>
  <p class="landing-desc">
    Stop managing your business. Start vibing.<br>
    Enter your website to generate a complete growth strategy.
  </p>
  <form id="landing-form" class="landing-form">
    <div class="landing-input-row">
      <div class="input-with-icon" style="flex: 1;">
        <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="2" y1="12" x2="22" y2="12"></line>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <input type="text" name="url" id="landing-url" class="input" placeholder="https://your-website.com" autocomplete="off" required style="padding-left: 48px;">
      </div>
      <button type="submit" class="btn btn-primary">
        Start Deep Research
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </div>
  </form>
  <div class="landing-examples">
    <span class="landing-examples-label">Try an example:</span>
    <button type="button" class="landing-example-btn" data-url="greenhydro.com">greenhydro.com</button>
    <button type="button" class="landing-example-btn" data-url="fitai.com">fitai.com</button>
    <button type="button" class="landing-example-btn" data-url="pawmeals.com">pawmeals.com</button>
  </div>
</div>
