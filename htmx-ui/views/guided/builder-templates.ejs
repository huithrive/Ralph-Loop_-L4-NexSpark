<div class="builder-templates">
  <div class="builder-templates-header">
    <h2>Choose a Template</h2>
    <p class="text-muted text-sm">Select a layout for your landing page</p>
  </div>

  <div class="builder-templates-grid">
    <% templates.forEach(function(t) { %>
      <div class="builder-template-card<%= t.recommended ? ' recommended' : '' %>"
           data-onboarding-action="pick-template-<%= t.id %>">
        <% if (t.recommended) { %>
          <div class="builder-template-badge">Recommended</div>
        <% } %>
        <div class="builder-template-icon">
          <% if (t.id === 'hero-bold') { %>
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="4" y="4" width="40" height="16" rx="3" stroke="currentColor" stroke-width="2"/><rect x="4" y="24" width="18" height="8" rx="2" stroke="currentColor" stroke-width="2"/><rect x="26" y="24" width="18" height="8" rx="2" stroke="currentColor" stroke-width="2"/><rect x="14" y="36" width="20" height="6" rx="3" fill="currentColor" opacity="0.3"/></svg>
          <% } else if (t.id === 'product-showcase') { %>
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="14" r="10" stroke="currentColor" stroke-width="2"/><rect x="4" y="28" width="12" height="8" rx="2" stroke="currentColor" stroke-width="2"/><rect x="18" y="28" width="12" height="8" rx="2" stroke="currentColor" stroke-width="2"/><rect x="32" y="28" width="12" height="8" rx="2" stroke="currentColor" stroke-width="2"/><rect x="14" y="40" width="20" height="4" rx="2" fill="currentColor" opacity="0.3"/></svg>
          <% } else if (t.id === 'story-scroll') { %>
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="8" y="4" width="32" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="8" y="14" width="32" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="8" y="24" width="32" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="8" y="34" width="32" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="16" y="44" width="16" height="2" rx="1" fill="currentColor" opacity="0.3"/></svg>
          <% } else { %>
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="10" y="10" width="28" height="12" rx="3" stroke="currentColor" stroke-width="2"/><rect x="14" y="28" width="20" height="8" rx="4" fill="currentColor" opacity="0.3"/><line x1="18" y1="40" x2="30" y2="40" stroke="currentColor" stroke-width="2" opacity="0.4"/></svg>
          <% } %>
        </div>
        <div class="builder-template-name"><%= t.name %></div>
        <div class="builder-template-desc"><%= t.description %></div>
        <div class="builder-template-tags">
          <% t.tags.forEach(function(tag) { %>
            <span class="builder-template-tag"><%= tag %></span>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>
</div>
