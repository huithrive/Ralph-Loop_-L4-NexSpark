<div class="interview-canvas">
  <div class="interview-header">
    <h2>Voice Interview</h2>
    <p class="text-muted text-sm mt-2">3 quick questions to personalize your strategy</p>
  </div>

  <div class="interview-steps">
    <% var questions = ['Ideal Customer', 'Differentiators', 'Budget & Goals']; %>
    <% questions.forEach(function(q, i) { %>
      <% var cls = i < step ? 'completed' : i === step ? 'active' : ''; %>
      <div class="interview-step <%= cls %>">
        <span class="step-num"><%= i < step ? '\u2713' : (i + 1) %></span>
        <span><%= q %></span>
      </div>
    <% }); %>
  </div>

  <div class="interview-answers">
    <% if (typeof answers !== 'undefined' && answers.length > 0) { %>
      <% answers.forEach(function(a, i) { %>
        <div class="interview-answer-card">
          <div class="answer-q">Q<%= i + 1 %>: <%= questions[i] %></div>
          <div class="answer-text"><%= a %></div>
        </div>
      <% }); %>
    <% } %>

    <% if (step < 3) { %>
      <div class="interview-waiting">
        Waiting for your answer
        <span class="waiting-dots"><span></span><span></span><span></span></span>
      </div>
    <% } else { %>
      <div class="interview-answer-card" style="border-color: var(--success); text-align: center;">
        <div class="text-success font-bold">Interview Complete</div>
        <div class="text-muted text-sm mt-2">Generating your GTM report...</div>
      </div>
    <% } %>
  </div>
</div>
