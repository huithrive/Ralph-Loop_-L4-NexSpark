<div class="animate-fade-in">
  <div class="page-header">
    <h1 class="page-title">Meta Pixel</h1>
    <p class="page-subtitle">Track conversions and optimize your ad delivery</p>
  </div>

  <div class="card mb-6">
    <div class="card-header">
      <h3 class="card-title">Pixel Status</h3>
      <span class="badge badge-success">Healthy</span>
    </div>
    <div class="grid-3 mb-4">
      <div>
        <div class="text-muted text-xs uppercase tracking-wide mb-1">Pixel ID</div>
        <div class="text-mono text-white font-bold"><%= pixel.pixelId %></div>
      </div>
      <div>
        <div class="text-muted text-xs uppercase tracking-wide mb-1">Status</div>
        <div class="flex items-center gap-2">
          <span class="status-dot" style="width: 6px; height: 6px;"></span>
          <span class="text-success font-bold"><%= pixel.status %></span>
        </div>
      </div>
      <div>
        <div class="text-muted text-xs uppercase tracking-wide mb-1">Events (24h)</div>
        <div class="text-gold font-bold text-lg"><%= pixel.eventsLast24h.toLocaleString() %></div>
      </div>
    </div>
  </div>

  <div class="card mb-6">
    <div class="card-header">
      <h3 class="card-title">Event Tracking</h3>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Event</th>
            <th>Count (24h)</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% pixel.topEvents.forEach(function(e) { %>
            <tr>
              <td class="font-bold text-white"><%= e.name %></td>
              <td class="text-gold"><%= e.count.toLocaleString() %></td>
              <td>
                <div class="flex items-center gap-2">
                  <span class="status-dot" style="width: 6px; height: 6px;"></span>
                  <span class="text-success text-sm"><%= e.status %></span>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Test Pixel</h3>
    </div>
    <p class="text-muted text-sm mb-4">Fire a test event to verify your pixel is working correctly.</p>
    <button class="btn btn-secondary" onclick="showToast('Test event fired! Check Events Manager.', 'success')">Fire Test Event</button>
  </div>
</div>
