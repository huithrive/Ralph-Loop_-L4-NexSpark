<div class="animate-fade-in">
  <div class="page-header">
    <h1 class="page-title">Platform Connections</h1>
    <p class="page-subtitle">Manage your advertising platform accounts</p>
  </div>

  <div class="grid-3" id="connection-grid">
    <% connections.forEach(function(conn) { %>
      <div class="card connection-card">
        <div class="connection-icon"><%= conn.icon %></div>
        <div class="connection-info">
          <div class="connection-name"><%= conn.platform %></div>
          <div class="connection-account"><%= conn.accountName %></div>
          <div class="text-muted text-xs mt-2">Last sync: <%= conn.lastSync %></div>
        </div>
        <div>
          <% if (conn.connected) { %>
            <div class="connection-status text-success">
              <span class="status-dot" style="width: 6px; height: 6px;"></span>
              <%= conn.status %>
            </div>
            <button class="btn btn-ghost btn-sm mt-2" onclick="showToast('Reconnecting...', 'info')">Reconnect</button>
          <% } else { %>
            <button class="btn btn-primary btn-sm" onclick="showToast('Connecting to ' + '<%= conn.platform %>' + '...', 'info')">Connect</button>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>
