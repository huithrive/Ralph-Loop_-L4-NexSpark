<div class="animate-fade-in">
  <div class="page-header">
    <h1 class="page-title">Landing Pages</h1>
    <p class="page-subtitle">Generate and manage high-converting landing pages</p>
  </div>

  <div class="card mb-6">
    <div class="card-header">
      <h3 class="card-title">Generate New Page</h3>
    </div>
    <form hx-post="/fragments/executor/landing-page-result"
          hx-target="#lp-output"
          hx-indicator="#lp-spinner">
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label">Page Name</label>
          <input type="text" name="name" class="form-input" placeholder="e.g., GreenHydro — Summer Sale">
        </div>
        <div class="form-group">
          <label class="form-label">Template</label>
          <select name="template" class="form-select">
            <option value="hero">Hero + Features</option>
            <option value="product">Product Showcase</option>
            <option value="comparison">Comparison</option>
            <option value="bundle">Bundle Offer</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Value Proposition</label>
        <textarea name="proposition" class="form-textarea" rows="2" placeholder="What makes this offer compelling?"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Generate Landing Page</button>
    </form>
  </div>

  <div id="lp-spinner" class="htmx-indicator">
    <%- include('../../partials/_loading', { loadingText: 'Generating landing page...' }) %>
  </div>

  <div id="lp-output"></div>

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Your Landing Pages</h3>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>URL</th>
            <th>Status</th>
            <th>Views</th>
            <th>Conversions</th>
            <th>CVR</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          <% pages.forEach(function(p) { %>
            <tr>
              <td class="font-bold text-white"><%= p.name %></td>
              <td class="text-mono text-sm"><%= p.url %></td>
              <td>
                <span class="badge badge-<%= p.status === 'live' ? 'success' : 'neutral' %>"><%= p.status %></span>
              </td>
              <td><%= p.views.toLocaleString() %></td>
              <td class="text-gold font-bold"><%= p.conversions %></td>
              <td><%= p.conversionRate %></td>
              <td class="text-muted"><%= p.createdAt %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
