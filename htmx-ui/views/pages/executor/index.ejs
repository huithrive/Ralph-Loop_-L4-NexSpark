<div class="animate-fade-in">
  <div class="page-header">
    <h1 class="page-title">Executor</h1>
    <p class="page-subtitle">Build landing pages, stores, and creatives from your GTM strategy</p>
  </div>

  <div class="grid-2">
    <div class="card card-clickable"
         hx-get="/executor/landing-pages"
         hx-target="#main-content"
         hx-push-url="true">
      <div class="module-icon">🌐</div>
      <div class="module-name">Landing Pages</div>
      <div class="module-desc">Generate high-converting landing pages from your research data</div>
      <div style="margin-top: 12px;">
        <span class="badge badge-success">3 pages created</span>
      </div>
    </div>

    <div class="card card-clickable"
         hx-get="/executor/shopify"
         hx-target="#main-content"
         hx-push-url="true">
      <div class="module-icon">🛍️</div>
      <div class="module-name">Shopify Store</div>
      <div class="module-desc">Set up your Shopify store with AI-generated products</div>
      <div style="margin-top: 12px;">
        <span class="badge badge-success">Connected</span>
        <span class="badge badge-info" style="margin-left: 4px;">8 products</span>
      </div>
    </div>

    <div class="card card-clickable"
         hx-get="/executor/domains"
         hx-target="#main-content"
         hx-push-url="true">
      <div class="module-icon">🔗</div>
      <div class="module-name">Domain Setup</div>
      <div class="module-desc">Search and register domains for your brand</div>
      <div style="margin-top: 12px;">
        <span class="badge badge-info">Search available</span>
      </div>
    </div>

    <div class="card card-clickable"
         hx-get="/executor/creative"
         hx-target="#main-content"
         hx-push-url="true">
      <div class="module-icon">🎨</div>
      <div class="module-name">Creative Studio</div>
      <div class="module-desc">Generate images and videos for your ad campaigns</div>
      <div style="margin-top: 12px;">
        <span class="badge badge-success">3 complete</span>
        <span class="badge badge-warning" style="margin-left: 4px;">2 in progress</span>
      </div>
    </div>
  </div>
</div>
