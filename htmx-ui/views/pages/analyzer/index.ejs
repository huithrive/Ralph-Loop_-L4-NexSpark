<div class="animate-fade-in">
  <div class="page-header flex justify-between items-center">
    <div>
      <h1 class="page-title">Performance Dashboard</h1>
      <p class="page-subtitle">Track campaign performance and ROI in real-time</p>
    </div>
    <div class="flex gap-3">
      <a class="btn btn-secondary btn-sm"
         href="/analyzer/optimize"
         hx-get="/analyzer/optimize"
         hx-target="#main-content"
         hx-push-url="true">Optimize</a>
    </div>
  </div>

  <div class="grid-4 mb-6">
    <% Object.values(kpis).forEach(function(kpi) { %>
      <%- include('../../partials/_kpi-card', { kpi }) %>
    <% }); %>
  </div>

  <div class="grid-2 mb-6">
    <div class="chart-container">
      <div class="card-header">
        <h3 class="card-title">Revenue vs Spend</h3>
      </div>
      <div style="height: 280px;">
        <canvas data-chart='<%- JSON.stringify({
          labels: chartData.labels,
          datasets: [
            { label: "Revenue", data: chartData.revenue, color: "gold" },
            { label: "Spend", data: chartData.spend, color: "blue" }
          ]
        }) %>'></canvas>
      </div>
    </div>

    <div class="chart-container">
      <div class="card-header">
        <h3 class="card-title">ROAS Trend</h3>
      </div>
      <div style="height: 280px;">
        <canvas data-chart='<%- JSON.stringify({
          labels: chartData.labels,
          datasets: [
            { label: "ROAS", data: chartData.roas, color: "green" }
          ]
        }) %>'></canvas>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Campaign Performance</h3>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Campaign</th>
            <th>Spend</th>
            <th>Revenue</th>
            <th>ROAS</th>
            <th>CPA</th>
            <th>CTR</th>
            <th>Conversions</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% performanceData.forEach(function(row) { %>
            <tr>
              <td class="font-bold text-white"><%= row.campaign %></td>
              <td><%= row.spend %></td>
              <td class="text-gold font-bold"><%= row.revenue %></td>
              <td class="text-success font-bold"><%= row.roas %></td>
              <td><%= row.cpa %></td>
              <td><%= row.ctr %></td>
              <td><%= row.conversions %></td>
              <td>
                <span class="badge badge-<%= row.status === 'active' ? 'success' : 'warning' %>"><%= row.status %></span>
              </td>
              <td>
                <a class="btn btn-ghost btn-sm"
                   href="/analyzer/performance?campaign=<%= row.campaign %>"
                   hx-get="/analyzer/performance?campaign=<%= row.campaign %>"
                   hx-target="#main-content"
                   hx-push-url="true">Details</a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
