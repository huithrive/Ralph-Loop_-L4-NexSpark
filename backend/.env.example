NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://username:password@localhost:5432/nexspark
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Strategist Part I runtime proxy target (Cloudflare Worker / deployed service)
# Example: https://nexspark-strategist.your-domain.workers.dev
STRATEGIST_RUNTIME_URL=
# Optional: auto-attach upstream auth when incoming request has no Authorization
STRATEGIST_RUNTIME_BEARER_TOKEN=
# Optional: send API key header to upstream strategist runtime
STRATEGIST_RUNTIME_API_KEY=

# Shopify Integration (Module 2)
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_APP_HOST=your-app-domain.com

# Domain Management (Module 2.3)
DNSIMPLE_API_KEY=your-dnsimple-api-key
DNSIMPLE_ACCOUNT_ID=your-dnsimple-account-id
NAMESILO_API_KEY=your-namesilo-api-key

# Creative Generation (Module 2.4)
PIXVERSE_API_KEY=your-pixverse-api-key
KLING_API_KEY=your-kling-api-key
RUNWAY_API_KEY=your-runway-api-key
OPENAI_API_KEY=your-openai-api-key
REPLICATE_API_TOKEN=your-replicate-token

# Advertiser Module (Module 3)
# GoMarble MCP (Primary) - Connects to Meta BM and Google Ads
GOMARBLE_MCP_URL=https://apps.gomarble.ai/mcp-api/sse
GOMARBLE_OAUTH_CLIENT_ID=your-gomarble-client-id
GOMARBLE_OAUTH_CLIENT_SECRET=your-gomarble-client-secret

# Meta Direct API (Fallback)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token

# Google Ads Direct API (Fallback)
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token