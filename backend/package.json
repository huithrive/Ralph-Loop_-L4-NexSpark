{
  "name": "nexspark-backend",
  "version": "1.0.0",
  "description": "NexSpark AI-powered growth strategy backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [
    "ai",
    "strategy",
    "growth",
    "market-research"
  ],
  "author": "NexSpark Team",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.8",
    "@shopify/shopify-api": "^12.3.0",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!tests/**"
    ]
  }
}
